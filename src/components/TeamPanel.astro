---
// "The minds behind Brink" — copy beside a photograph of the team.
//
// Replaces an earlier headshot grid, which was the wrong idea: a wall of
// six faces out of 27 said nothing about who Brink is, and the /team page
// already does that job properly. The copy carries the point (multi-
// disciplinary, multi-continent, "of the places we work") and the photo
// carries the feeling.
import { withBase } from '../lib/base';

interface Props {
  heading?: string;
  image: string;
  imageAlt: string;
  /** Photo on the left instead of the right. */
  flip?: boolean;
}

const {
  heading = 'The minds behind Brink',
  image,
  imageAlt,
  flip = false,
} = Astro.props;
---

<section class="team-panel">
  <div class:list={['container', 'panel-inner', { flip }]}>
    <div class="panel-copy">
      <h2 class="display">{heading}</h2>
      <slot />
      <a class="button" href={withBase('/team')}>Meet the team</a>
    </div>
    <img class="panel-photo" src={withBase(image)} alt={imageAlt} loading="lazy" />
  </div>
</section>

<style>
  .team-panel {
    padding: var(--space-9) 0;
    background: var(--color-surface-muted);
  }

  .panel-inner {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: var(--space-8);
    align-items: center;
  }

  .panel-inner.flip .panel-copy {
    order: 2;
  }

  .panel-copy h2 {
    font-size: var(--text-display);
    margin: 0 0 var(--space-5);
  }

  .panel-copy :global(p) {
    margin: 0 0 var(--space-4);
    font-size: var(--text-body-sm);
    line-height: var(--leading-normal);
  }

  .panel-photo {
    width: 100%;
    height: 100%;
    max-height: 30rem;
    object-fit: cover;
    border-radius: var(--radius);
    display: block;
  }

  @media (max-width: 860px) {
    .panel-inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    /* Photo first on a phone — it's the faster read. */
    .panel-inner.flip .panel-copy,
    .panel-copy {
      order: 2;
    }
    .panel-photo {
      order: 1;
      max-height: 22rem;
    }
  }
</style>
