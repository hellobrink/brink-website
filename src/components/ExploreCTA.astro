---
import { withBase } from '../lib/base';
---

<section class="explore-cta">
  <div class="container">
    <h2 class="display">
      If you want to explore how we can work together to shift systems,
      transform mindsets, and create new possibilities, we'd love to hear
      from you.
    </h2>
    <div class="contact">
      <img
        src={withBase('/images/66f19135374bb74b702fe546_66d6150d565356fb8e364cd7_alex_1.webp')}
        alt="Alex, Innovation Director at Brink"
        class="photo"
      />
      <p>
        The best person to get in touch with is Alex, our Innovation Director
        and you can email her on <a href="mailto:alex@hellobrink.co">alex@hellobrink.co</a>.
      </p>
    </div>
    <a class="button" href="mailto:alex@hellobrink.co">Get in touch</a>
  </div>
</section>

<style>
  .explore-cta {
    padding: var(--space-8) 0 var(--space-9);
    border-top: 1px solid var(--color-border);
  }

  h2.display {
    font-size: var(--text-display);
    max-width: var(--measure-narrow);
    margin-bottom: var(--space-6);
  }

  .contact {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .photo {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-circle);
    object-fit: cover;
    flex-shrink: 0;
  }

  .contact p {
    margin: 0;
    max-width: var(--measure-narrow);
    color: var(--color-text-muted);
  }
</style>
