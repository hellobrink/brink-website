---
import { withBase } from '../lib/base';

interface Props {
  value: string;
  label: string;
  caseStudySlug?: string;
}
const { value, label, caseStudySlug } = Astro.props;
const Tag = caseStudySlug ? 'a' : 'div';
---

<Tag class="impact-metric" href={caseStudySlug ? withBase(`/our-work/${caseStudySlug}`) : undefined}>
  <span class="value">{value}</span>
  <span class="label">{label}</span>
</Tag>

<style>
  .impact-metric {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: var(--space-4) 0;
  }

  .value {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-display);
    color: var(--color-accent);
  }

  .label {
    display: block;
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
  }

  a.impact-metric:hover .value {
    text-decoration: underline;
  }
</style>
