---
// Behavioural Innovation, drawn rather than shipped as a PNG.
//
// The original (public/images/illo-bi-venn.png) is a hand-drawn coral Venn:
// two circles, a hatched intersection, an arrow pointing up at the overlap.
// Rebuilt as SVG so it scales, themes from the tokens, stays sharp, and can
// do the one thing a flat image can't — perform the idea. The circles start
// apart and converge on scroll, so the overlap is something you watch happen.
//
// Geometry notes, because they're load-bearing:
//   circles  r=150 at cx 250 / 370, cy 180  -> bottoms at y=330
//   lens     the two circles intersect at x=310, y=42.5 and y=317.5
//   arrow    tip at y=352 — clear of the circles (whose 7px stroke reaches
//            y=333.5), so it points at the lens without touching it
//   labels   sit INSIDE each circle's non-overlapping crescent
//            (left-only 100–220, right-only 400–520), not floating outside
//
// Colour: strokes inherit `currentColor`. Label fill is a separate custom
// property so a dark panel can keep the circles coral while the labels go
// paper white.

interface Props {
  left?: [string, string];
  right?: [string, string];
}
const {
  left = ['Behavioural', 'sciences'],
  right = ['Innovation', 'methods'],
} = Astro.props;
---

<figure class="venn">
  <svg viewBox="0 0 620 470" role="img" aria-labelledby="venn-title">
    <title id="venn-title">
      {left.join(' ')} combined with {right.join(' ')} produces behavioural innovation
    </title>

    <defs>
      <pattern id="venn-hatch" width="9" height="9" patternUnits="userSpaceOnUse" patternTransform="rotate(70)">
        <line x1="0" y1="0" x2="0" y2="9" stroke="currentColor" stroke-width="3.2" />
      </pattern>
      {/* The lens is the intersection: clip one circle by the other. */}
      <clipPath id="venn-lens">
        <circle cx="250" cy="180" r="150" />
      </clipPath>
    </defs>

    <g class="circle-left">
      <circle cx="250" cy="180" r="150" fill="none" stroke="currentColor" stroke-width="7" />
      <text class="venn-label" x="160" y="172" text-anchor="middle">{left[0]}</text>
      <text class="venn-label" x="160" y="196" text-anchor="middle">{left[1]}</text>
    </g>

    <g class="circle-right">
      <circle cx="370" cy="180" r="150" fill="none" stroke="currentColor" stroke-width="7" />
      {/* Hatch rides with the right circle so it lands exactly on the lens. */}
      <circle cx="370" cy="180" r="150" fill="url(#venn-hatch)" clip-path="url(#venn-lens)" />
      <text class="venn-label" x="460" y="172" text-anchor="middle">{right[0]}</text>
      <text class="venn-label" x="460" y="196" text-anchor="middle">{right[1]}</text>
    </g>

    <g class="venn-pointer">
      <path d="M310 460 L310 356" fill="none" stroke="currentColor" stroke-width="7" stroke-linecap="round" />
      <path d="M288 378 L310 352 L332 378" fill="none" stroke="currentColor" stroke-width="7"
            stroke-linecap="round" stroke-linejoin="round" />
    </g>
  </svg>
</figure>

<style>
  .venn {
    margin: 0;
  }

  .venn svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .venn-label {
    font-family: var(--font-mono);
    font-size: 15px;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    /* Falls back to the stroke colour; a dark panel overrides it so the
       labels stay legible inside coral circles. */
    fill: var(--venn-label-color, currentColor);
  }

  /* Resting state: circles pushed apart, so there is no overlap yet. */
  .circle-left,
  .circle-right,
  .venn-pointer {
    transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.6s ease;
  }

  .circle-left {
    transform: translateX(-60px);
  }

  .circle-right {
    transform: translateX(60px);
  }

  .venn-pointer {
    opacity: 0;
    transform: translateY(var(--space-4));
  }

  .venn.in .circle-left,
  .venn.in .circle-right {
    transform: translateX(0);
  }

  .venn.in .venn-pointer {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.65s; /* arrives after the circles have met */
  }

  /* The convergence is decorative, so reduced motion just gets the finished
     diagram. */
  @media (prefers-reduced-motion: reduce) {
    .circle-left,
    .circle-right {
      transform: translateX(0);
    }
    .venn-pointer {
      opacity: 1;
      transform: none;
    }
    .circle-left,
    .circle-right,
    .venn-pointer {
      transition: none;
    }
  }
</style>

<script>
  // Converge on first view only — replaying it every scroll-past would be a
  // fidget, not a point.
  const venns = document.querySelectorAll<HTMLElement>('.venn');
  if (venns.length) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('in');
          io.unobserve(entry.target);
        });
      },
      { threshold: 0.35 }
    );
    venns.forEach((v) => io.observe(v));
  }
</script>
