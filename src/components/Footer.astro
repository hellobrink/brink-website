---
import { withBase } from '../lib/base';

// Matches the live site's footer: light background, 10px solid coral top
// border, dark teal text, mono uppercase labels.
const sectors = [
  { href: '/sectors/climate', label: 'Climate' },
  { href: '/sectors/health', label: 'Health' },
  { href: '/sectors/education', label: 'Education' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p class="mono">© Brink Innovation Limited</p>
      <p class="mono address">
        Brink Innovation Ltd<br />
        86-90 Paul Street<br />
        London<br />
        EC2A 4NE
      </p>
      <p class="mono"><a href="mailto:coffee@hellobrink.co">coffee@hellobrink.co</a></p>
      <p class="mono"><a href={withBase('/privacy-policy')}>Privacy policy</a></p>
    </div>
    <div>
      <p class="mono">Sectors</p>
      <ul>
        {sectors.map((s) => (
          <li><a href={withBase(s.href)}>{s.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <p class="mono">Subscribe to our monthly newsletter</p>
      <a class="button" href="mailto:coffee@hellobrink.co?subject=Newsletter%20signup">Click here</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 10px solid var(--brand-red);
    background: #fff;
    color: var(--brand-green);
    margin-top: 4rem;
    padding: 41px 0 63px;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    justify-content: space-between;
  }

  .footer-inner a {
    color: var(--brand-green);
    text-decoration: none;
  }

  .footer-inner a:hover {
    color: var(--brand-red);
  }

  .footer-inner ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-inner li a {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.9rem;
    line-height: 1.9;
  }

  .address {
    line-height: 1.7;
  }

  .mono {
    margin-bottom: 11px;
  }
</style>
