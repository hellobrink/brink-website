---
import { getEntry, render } from 'astro:content';

interface Props {
  slug: string;
}
const { slug } = Astro.props;
const entry = await getEntry('pages', slug);
const { Content } = entry ? await render(entry) : { Content: null };
---

<div class="container prose">
  {Content ? <Content /> : <p>Content for "{slug}" not found — run <code>npm run scrape</code>.</p>}
</div>

<style>
  .prose {
    padding: 2rem 0 4rem;
    max-width: 70ch;
  }

  /* Scraped content mixes photos with logo/sticker images — render at
     natural size (capped) rather than stretching everything full-width. */
  .prose :global(img) {
    width: auto;
    max-width: 100%;
    max-height: 480px;
    margin: 1.5rem 0;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 1.9rem;
    line-height: 1.3;
    margin-top: 2rem;
  }
</style>
