---
import { withBase } from '../lib/base';

interface Props {
  /** Sit transparent over a hero image rather than on a solid teal bar. */
  overlay?: boolean;
}
const { overlay = false } = Astro.props;

// Horizontal nav with dropdowns, replacing the hamburger-everywhere pattern
// inherited from Webflow (which hid the whole site behind a click even on a
// 1440px screen). Grouping under "Our work" is what makes room for sectors
// without the top level growing unboundedly — see Decision 3 in the brief.
const navItems: Array<{
  href: string;
  label: string;
  children?: Array<{ href: string; label: string }>;
}> = [
  { href: '/about', label: 'About Brink' },
  {
    href: '/our-work',
    label: 'Our work',
    children: [
      { href: '/our-work', label: 'Case studies' },
      { href: '/sectors/climate', label: 'Climate' },
      { href: '/sectors/health', label: 'Health' },
      { href: '/sectors/education', label: 'Education' },
    ],
  },
  {
    href: '/offers',
    label: 'Our offers',
    children: [
      { href: '/offers/open-innovation', label: 'Open Innovation' },
      { href: '/offers/carve-outs', label: 'Innovation Carve-Outs' },
      { href: '/offers/missions', label: 'Innovation Missions' },
    ],
  },
  { href: '/team', label: 'Team' },
  { href: '/foundation', label: 'Foundation' },
  { href: '/blog', label: 'Blog' },
];
---

<header class:list={['site-header', { overlay }]}>
  <div class="header-inner">
    <a href={withBase('/')} class="brand" aria-label="Brink — home">
      <img src={withBase('/images/brink-logo-white.webp')} alt="Brink" width="110" />
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class:list={['nav-item', { 'has-children': item.children }]}>
            <a href={withBase(item.href)}>{item.label}</a>
            {item.children && (
              <ul class="submenu">
                {item.children.map((child) => (
                  <li><a href={withBase(child.href)}>{child.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <button class="search-toggle" aria-label="Search" aria-expanded="false" aria-controls="site-search">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <circle cx="11" cy="11" r="7" />
        <line x1="16.5" y1="16.5" x2="21" y2="21" />
      </svg>
    </button>

    <a class="header-cta" href="mailto:coffee@hellobrink.co">Work with us</a>

    <button class="menu-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div id="site-search" class="site-search" data-index={withBase('/search.json')} hidden>
    <div class="search-inner">
      <label class="mono" for="search-input">Search Brink</label>
      <input
        id="search-input"
        type="search"
        autocomplete="off"
        placeholder="Case studies, people, sectors&hellip;"
      />
      <p class="mono search-status" role="status" aria-live="polite"></p>
      <ul class="search-results"></ul>
    </div>
  </div>

  <nav id="mobile-menu" class="mobile-menu" aria-label="Primary (mobile)" hidden>
    <ul>
      {navItems.map((item) => (
        <li>
          <a href={withBase(item.href)}>{item.label}</a>
          {item.children && (
            <ul>
              {item.children.map((child) => (
                <li><a href={withBase(child.href)}>{child.label}</a></li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.classList.toggle('open', !open);
    if (menu) menu.hidden = open;
  });

  // Dropdowns open on hover, but hover alone is unusable on touch and
  // invisible to keyboards — so also open on focus within the item.
  document.querySelectorAll('.nav-item.has-children').forEach((item) => {
    const link = item.querySelector(':scope > a');
    link?.addEventListener('focus', () => item.classList.add('open'));
    item.addEventListener('focusout', (e) => {
      if (!item.contains(e.relatedTarget as Node)) item.classList.remove('open');
    });
  });

  // --- Site search ---------------------------------------------------------
  // No backend, so /search.json is a build-time index of every record and the
  // filtering happens here. It's fetched on first open rather than on page
  // load — most visits never search, and the index shouldn't cost them.
  const searchToggle = document.querySelector('.search-toggle');
  const searchPanel = document.getElementById('site-search');
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const searchResults = document.querySelector('.search-results');
  const searchStatus = document.querySelector('.search-status');

  if (searchToggle && searchPanel && searchInput && searchResults && searchStatus) {
    type Doc = { title: string; url: string; kind: string; text: string };
    let docs: Doc[] | null = null;
    let loading = false;

    // Base-path aware, written server-side by withBase(). A relative URL
    // would resolve against the current page and 404 on nested routes.
    const indexUrl = searchPanel.dataset.index!;

    const loadDocs = async () => {
      if (docs || loading) return;
      loading = true;
      try {
        docs = await (await fetch(indexUrl)).json();
      } catch {
        searchStatus.textContent = 'Search is unavailable right now.';
      }
      loading = false;
    };

    const render = () => {
      const q = searchInput.value.trim().toLowerCase();
      searchResults.innerHTML = '';
      if (!q) {
        searchStatus.textContent = '';
        return;
      }
      if (!docs) {
        searchStatus.textContent = 'Loading…';
        return;
      }
      // Title matches first — someone typing "Lea" wants the person, not
      // every case study that mentions her.
      const hits = docs
        .map((d) => {
          const inTitle = d.title.toLowerCase().includes(q);
          const inText = d.text.toLowerCase().includes(q);
          return inTitle || inText ? { d, rank: inTitle ? 0 : 1 } : null;
        })
        .filter((x): x is { d: Doc; rank: number } => x !== null)
        .sort((a, b) => a.rank - b.rank)
        .slice(0, 12);

      searchStatus.textContent = hits.length
        ? `${hits.length}${hits.length === 12 ? '+' : ''} result${hits.length === 1 ? '' : 's'}`
        : 'No results';

      hits.forEach(({ d }) => {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = d.url;
        a.innerHTML = `<span class="result-title"></span><span class="mono result-kind"></span>`;
        // textContent, not innerHTML — titles are content, not markup.
        a.querySelector('.result-title')!.textContent = d.title;
        a.querySelector('.result-kind')!.textContent = d.kind;
        li.appendChild(a);
        searchResults.appendChild(li);
      });
    };

    const openSearch = async () => {
      searchPanel.hidden = false;
      searchToggle.setAttribute('aria-expanded', 'true');
      searchToggle.classList.add('open');
      searchInput.focus();
      await loadDocs();
      render(); // in case they typed before the index landed
    };

    const closeSearch = () => {
      searchPanel.hidden = true;
      searchToggle.setAttribute('aria-expanded', 'false');
      searchToggle.classList.remove('open');
    };

    searchToggle.addEventListener('click', () =>
      searchPanel.hidden ? openSearch() : closeSearch()
    );
    searchInput.addEventListener('input', render);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !searchPanel.hidden) {
        closeSearch();
        (searchToggle as HTMLElement).focus();
      }
    });
    // Click outside to dismiss, but not when the click is the toggle itself
    // (that would close and immediately reopen).
    document.addEventListener('click', (e) => {
      const t = e.target as Node;
      if (!searchPanel.hidden && !searchPanel.contains(t) && !searchToggle.contains(t)) {
        closeSearch();
      }
    });
  }

  // An overlay header is unreadable once it scrolls off the hero, so give it
  // its solid background back.
  const header = document.querySelector('.site-header.overlay');
  if (header) {
    const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 80);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  .site-header {
    background: var(--color-surface-inverted);
    color: var(--color-surface);
    position: sticky;
    top: 0;
    z-index: 50;
    transition: background var(--transition);
  }

  /* Over a hero photo: transparent, with a soft scrim so white nav text
     stays legible against whatever is behind it. */
  .site-header.overlay {
    position: fixed;
    left: 0;
    right: 0;
    background: linear-gradient(to bottom, rgba(6, 51, 61, 0.55), transparent);
  }

  .site-header.overlay.scrolled {
    background: var(--color-surface-inverted);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-3) var(--space-gutter);
  }

  .brand img {
    display: block;
    width: 110px;
    height: auto;
  }

  .primary-nav {
    margin-left: auto;
  }

  .nav-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-item > a {
    display: block;
    padding: var(--space-3) 0;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-surface);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-item > a:hover {
    color: var(--color-accent);
  }

  /* The coral underline is the hover affordance — square, like everything
     else in the brand. */
  .nav-item > a::after {
    content: '';
    display: block;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }

  .nav-item > a:hover::after {
    transform: scaleX(1);
  }

  .submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 220px;
    list-style: none;
    margin: 0;
    padding: var(--space-2) 0;
    background: var(--color-surface-inverted);
    border-top: 2px solid var(--color-accent);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition);
  }

  .nav-item:hover .submenu,
  .nav-item.open .submenu {
    opacity: 1;
    visibility: visible;
  }

  .submenu a {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-body-sm);
    color: var(--color-surface);
    text-decoration: none;
    white-space: nowrap;
  }

  .submenu a:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-accent);
  }

  .header-cta {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    padding: var(--space-2) var(--space-4);
    border: var(--border-width-button) solid var(--color-surface);
    color: var(--color-surface);
    text-decoration: none;
    white-space: nowrap;
    transition: background var(--transition), color var(--transition);
  }

  .header-cta:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  /* --- Search ------------------------------------------------------------ */
  .search-toggle {
    display: grid;
    place-items: center;
    width: var(--space-6);
    height: var(--space-6);
    padding: 0;
    background: none;
    border: none;
    color: var(--color-surface);
    cursor: pointer;
  }

  .search-toggle svg {
    width: var(--space-5);
    height: var(--space-5);
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
  }

  .search-toggle:hover,
  .search-toggle.open {
    color: var(--color-accent);
  }

  .site-search {
    background: var(--color-surface-inverted);
    border-top: var(--border-width) solid rgba(255, 255, 255, 0.15);
  }

  .search-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-5) var(--space-gutter) var(--space-6);
  }

  .search-inner label {
    display: block;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .search-inner input {
    width: 100%;
    padding: var(--space-3) 0;
    background: transparent;
    border: none;
    border-bottom: var(--border-width-button) solid var(--color-surface);
    border-radius: var(--radius);
    color: var(--color-surface);
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--text-h1);
  }

  .search-inner input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .search-inner input:focus {
    outline: none;
    border-bottom-color: var(--color-accent);
  }

  .search-status {
    color: var(--color-text-muted);
    margin: var(--space-3) 0 0;
    min-height: 1em; /* reserve the line so results don't jump as it fills */
  }

  .search-results {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    max-height: 50vh;
    overflow-y: auto;
    /* Clear the scrollbar so the right-hand kind labels aren't clipped by it
       on narrow screens. */
    padding-right: var(--space-3);
  }

  /* :global() because the result rows are built in JS. Astro scopes styles
     by stamping a data attribute on elements it renders — nodes created with
     createElement never get it, so a plain `.search-results a` rule compiles
     to a selector that cannot match them and the rows fall back to the
     default link styling. */
  .search-results :global(a) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: var(--border-width) solid rgba(255, 255, 255, 0.12);
    color: var(--color-surface);
    text-decoration: none;
  }

  .search-results :global(a:hover .result-title) {
    color: var(--color-accent);
  }

  .search-results :global(.result-kind) {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-3);
    flex-direction: column;
    gap: var(--space-1);
    margin-left: auto;
  }

  .menu-toggle span {
    display: block;
    width: 26px;
    height: 2px;
    background: var(--color-surface);
    transition: transform var(--transition), opacity var(--transition);
  }

  .menu-toggle.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .menu-toggle.open span:nth-child(2) { opacity: 0; }
  .menu-toggle.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    background: var(--color-surface-inverted);
    padding: var(--space-4) var(--space-gutter) var(--space-7);
  }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-menu > ul > li > a {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--text-h2);
    color: var(--color-surface);
    text-decoration: none;
    padding: var(--space-2) 0;
  }

  .mobile-menu ul ul {
    padding: 0 0 var(--space-3) var(--space-4);
  }

  .mobile-menu ul ul a {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-inverted);
    text-decoration: none;
    padding: var(--space-1) 0;
    opacity: 0.75;
  }

  /* Below this the horizontal nav can't fit without crowding, so fall back
     to the hamburger. */
  @media (max-width: 1024px) {
    .primary-nav,
    .header-cta {
      display: none;
    }
    .menu-toggle {
      display: flex;
      margin-left: 0;
    }
    /* With the nav and CTA gone, search is what pushes the controls right. */
    .search-toggle {
      margin-left: auto;
    }
    /* Only when the toggle has opened it — `:not([hidden])`. A bare
       `display: block` would beat the [hidden] attribute's UA style and
       leave the menu permanently open, shoving the hero down the page. */
    .mobile-menu:not([hidden]) {
      display: block;
    }
    .site-header.overlay {
      position: sticky;
      background: var(--color-surface-inverted);
    }
  }
</style>
