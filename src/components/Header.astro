---
import { withBase } from '../lib/base';

// Matches the live site's navbar: dark teal bar, white boxed BRINK logo
// left, hamburger right (desktop included). The menu opens as a dark
// overlay with large Signifier links (.nav-link-2 on the live site is
// Signifier 300 at 2rem, white).
//
// Nav structure keeps roughly today's items (Decision 3 in the brief —
// nav redesign — is deferred). "Our Work" and "Case Studies" are merged
// into one item since they're one collection now (Decision 1); "Blog" is
// dropped for v1 (no blog collection built yet).
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Brink' },
  { href: '/offers', label: 'Our offers' },
  { href: '/our-work', label: 'Our work' },
  { href: '/sectors', label: 'Sectors' },
  { href: '/team', label: 'Meet the team' },
  { href: '/foundation', label: 'Brink Foundation' },
  { href: '/blog', label: 'Blog' },
  { href: '/careers', label: 'Careers' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href={withBase('/')} class="brand">
      <img src={withBase('/images/brink-logo-white.webp')} alt="Brink" width="122" />
    </a>
    <button class="menu-toggle" aria-label="Menu" aria-expanded="false" aria-controls="site-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <nav id="site-menu" class="site-menu" aria-label="Primary" hidden>
    <ul>
      {navItems.map((item) => (
        <li><a href={withBase(item.href)}>{item.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const menu = document.getElementById('site-menu');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.classList.toggle('open', !open);
    if (menu) menu.hidden = open;
    document.body.classList.toggle('menu-open', !open);
  });
</script>

<style>
  .site-header {
    background: var(--color-surface-inverted);
    color: var(--color-surface);
    position: relative;
    z-index: 20;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-gutter);
  }

  .brand img {
    display: block;
    width: 122px;
    height: auto;
  }

  .menu-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .menu-toggle span {
    display: block;
    width: 28px;
    height: 3px;
    background: var(--color-surface);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .menu-toggle.open span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .menu-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.open span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .site-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-surface-inverted);
    padding: var(--space-6) 24px var(--space-8);
    box-shadow: 0 12px 24px rgba(6, 51, 61, 0.25);
  }

  .site-menu ul {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: var(--max-width);
  }

  .site-menu a {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--text-display);
    line-height: 1.7;
    color: var(--color-surface);
    text-decoration: none;
  }

  .site-menu a:hover {
    text-decoration: underline;
  }
</style>
