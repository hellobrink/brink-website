---
import { getEntry, render } from 'astro:content';
import { withBase } from '../lib/base';

// Shared across every sector page — one record, referenced rather than
// duplicated (per the restructure brief).
const entry = await getEntry('shared', 'behavioural-panel');
const { Content } = entry ? await render(entry) : { Content: null };
---

{entry && (
  <section class="behavioural-panel">
    <div class="container panel-inner">
      <div class="prose">
        <h2>{entry.data.title}</h2>
        <Content />
      </div>
      {entry.data.image && (
        <img
          class="panel-image"
          src={withBase(entry.data.image)}
          alt={entry.data.imageAlt ?? ''}
        />
      )}
    </div>
  </section>
)}

<style>
  .behavioural-panel {
    background: var(--type-main);
    color: var(--background-muted);
    padding: 3rem 0;
    margin: 3rem 0;
  }

  .behavioural-panel h2 {
    color: var(--background-muted);
  }

  .panel-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .prose {
    flex: 1;
    min-width: 240px;
  }

  .prose :global(p) {
    max-width: 60ch;
  }

  .panel-image {
    max-width: 280px;
    width: 100%;
    height: auto;
  }
</style>
