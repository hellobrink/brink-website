---
// "Our impact" — the programme logos, each linking out to the programme.
//
// Distinct from LogoStrip, which renders funder/partner *names* as small text
// badges inside a case study. This is the full-width showcase block: real
// logomarks, on a white tile, with an explicit read-more.
//
// Logos are third-party brand assets in every conceivable shape, colour and
// aspect ratio. The tile normalises them: a fixed-height box, `object-fit:
// contain`, a white ground (which is what every one of these marks was drawn
// for), and generous padding so nothing crowds the edge.
//
// No name caption: every one of these logos already contains its programme's
// name, so printing it again underneath just says it twice.
import { withBase } from '../lib/base';

export interface LogoItem {
  name: string;
  logo: string;
  href: string;
}

interface Props {
  heading?: string;
  intro?: string;
  items: LogoItem[];
}

const { heading = 'Our impact', intro, items } = Astro.props;
---

<section class="logo-grid-section">
  <div class="container">
    <h2 class="display section-heading">{heading}</h2>
    {intro && <p class="intro">{intro}</p>}

    <ul class="logo-grid">
      {items.map((item) => (
        <li>
          <a
            class="logo-card"
            href={item.href}
            {...(item.href.startsWith('http')
              ? { target: '_blank', rel: 'noopener noreferrer' }
              : {})}
          >
            <span class="logo-tile">
              {/* Every one of these marks contains the programme's own name,
                  so a caption underneath just says it twice. That makes the
                  logo the only label — which is exactly why alt text is the
                  programme name here rather than empty. */}
              <img src={withBase(item.logo)} alt={item.name} loading="lazy" />
            </span>
            <span class="mono logo-more">Read more &rarr;</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .logo-grid-section {
    padding: var(--space-9) 0;
    background: var(--color-surface-muted);
    /* Single source of truth for the tile box — the image's max-height is
       calculated from these, so they cannot disagree. */
    --logo-tile-height: calc(var(--space-10) * 1.6);
    --logo-tile-pad: var(--space-5);
  }

  .section-heading {
    font-size: var(--text-display);
    margin: 0 0 var(--space-4);
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: var(--measure-narrow);
    margin: 0 auto var(--space-8);
    color: var(--color-text);
  }

  .logo-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }

  .logo-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    height: 100%;
    text-decoration: none;
    color: var(--color-text);
    text-align: center;
  }

  /* White, not paper: these marks were drawn for white, and several have a
     baked-in white background that would otherwise show as a bright rectangle
     against the paper tone. */
  .logo-tile {
    display: grid;
    place-items: center;
    width: 100%;
    height: var(--logo-tile-height);
    padding: var(--logo-tile-pad);
    background: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
  }

  /* NO PERCENTAGE HEIGHTS. This bit is fiddly and cost three wrong fixes.
     A percentage height (or max-height) on a child of this tile resolves
     against the tile's height — but the child is also participating in the
     tile's alignment, which makes the dependency cyclic, so the browser
     quietly resolves it to `auto`. The image then falls back to its intrinsic
     aspect ratio, grows past the tile, and gets sliced by `overflow: hidden`.
     `max-height: 100%`, `aspect-ratio`, and `place-items: stretch` all failed
     for exactly this reason.

     Bounding the image with an absolute calc instead removes the cycle: the
     max-height is derived from the same two tokens as the tile, so the two
     can't drift apart. */
  .logo-tile img {
    max-width: 100%;
    max-height: calc(var(--logo-tile-height) - var(--logo-tile-pad) * 2);
    width: auto;
    height: auto;
    /* Third-party marks arrive in a riot of colours. Muting them at rest
       lets the grid read as one block; full colour on hover rewards
       attention and confirms the card is interactive. */
    filter: grayscale(1);
    opacity: 0.75;
    transition: filter var(--transition), opacity var(--transition);
  }

  .logo-card:hover .logo-tile img {
    filter: none;
    opacity: 1;
  }

  /* Teal, per the coral size threshold — coral at this size on a light
     ground is 3.01:1 and fails AA. */
  .logo-more {
    font-size: var(--text-tag);
    color: var(--color-label);
  }

  .logo-card:hover .logo-more {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
