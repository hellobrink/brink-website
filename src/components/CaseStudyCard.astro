---
import { withBase } from '../lib/base';

interface Props {
  slug: string;
  title: string;
  headlineResult?: string;
  heroImage?: string;
  heroAlt?: string;
}
const { slug, title, headlineResult, heroImage, heroAlt } = Astro.props;
---

<a class="case-card" href={withBase(`/our-work/${slug}`)}>
  {heroImage && <img src={withBase(heroImage)} alt={heroAlt ?? title} />}
  <div class="case-card-body">
    {headlineResult && <p class="result">{headlineResult}</p>}
    <h3>{title}</h3>
  </div>
</a>

<style>
  .case-card {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    border: var(--border-width) solid var(--color-border);
  }

  .case-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .case-card-body {
    padding: var(--space-4);
  }

  .case-card h3 {
    font-size: var(--text-h3);
    margin: 0;
  }

  .result {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: var(--text-tag);
    letter-spacing: 0.03em;
    color: var(--color-accent);
    margin: 0 0 0.4em;
  }

  .case-card:hover h3 {
    color: var(--color-accent);
  }
</style>
