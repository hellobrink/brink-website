---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { getCollection } from 'astro:content';

const sectors = await getCollection('sectors');
---

<Layout title="Sectors" description="Where Brink works: climate, health and education.">
  <div class="container">
    <header class="page-header">
      <h1>Sectors</h1>
    </header>
    <ul class="sector-grid">
      {sectors.map((sector) => (
        <li>
          <a href={withBase(`/sectors/${sector.id}`)}>
            <h2>{sector.data.name}</h2>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .page-header {
    padding: var(--space-6) 0 var(--space-4);
  }

  .sector-grid {
    list-style: none;
    margin: 0 0 var(--space-9);
    padding: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .sector-grid a {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    border-radius: var(--radius);
    padding: var(--space-6);
    text-align: center;
    border: var(--border-width) solid var(--color-border);
  }

  .sector-grid a:hover h2 {
    color: var(--color-accent);
  }
</style>
