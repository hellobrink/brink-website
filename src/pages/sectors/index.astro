---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { getCollection } from 'astro:content';

const sectors = await getCollection('sectors');
---

<Layout title="Sectors" description="Where Brink works: climate, health and education.">
  <div class="container">
    <header class="page-header">
      <h1>Sectors</h1>
    </header>
    <ul class="sector-grid">
      {sectors.map((sector) => (
        <li>
          <a href={withBase(`/sectors/${sector.id}`)}>
            <h2>{sector.data.name}</h2>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .page-header {
    padding: 2rem 0 1rem;
  }

  .sector-grid {
    list-style: none;
    margin: 0 0 4rem;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .sector-grid a {
    display: block;
    text-decoration: none;
    color: var(--type-main);
    background: white;
    border-radius: 0;
    padding: 2rem;
    text-align: center;
    border: 1px solid var(--background-faded);
  }

  .sector-grid a:hover h2 {
    color: var(--brand-red);
  }
</style>
