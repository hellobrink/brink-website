---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { data } = post;

// Link each byline to the author's bio where they're one of ours.
const team = await getCollection('team');
const bio = (slug?: string) => (slug ? team.find((m) => m.id === slug) : undefined);
const authors = [
  { name: data.authorName, member: bio(data.authorSlug) },
  data.authorName2 ? { name: data.authorName2, member: bio(data.authorSlug2) } : null,
].filter(Boolean) as { name: string; member: any }[];
---

<Layout title={data.title} description={data.subheading ?? data.summary}>
  <article class="post">
    <div class="container narrow">
      <p class="back"><a href={withBase('/blog')}>&larr; All posts</a></p>
      <h1>{data.title}</h1>
      <p class="byline mono">
        {authors.map((a, i) => (
          <>
            {i > 0 ? ' & ' : ''}
            {a.member ? (
              <a href={withBase(`/team/${a.member.id}`)}>{a.name}</a>
            ) : (
              a.name
            )}
          </>
        ))}
        {data.date && authors.length > 0 ? ' · ' : ''}
        {data.date}
      </p>
      {data.subheading && <p class="standfirst">{data.subheading}</p>}
    </div>

    {data.bannerImage && (
      <figure class="post-banner">
        <img src={withBase(data.bannerImage)} alt={data.bannerAlt ?? data.title} />
      </figure>
    )}

    <div class="container narrow">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .post {
    padding-top: var(--space-6);
    padding-bottom: var(--space-9);
  }

  .narrow {
    max-width: var(--measure);
  }

  .back a {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .post h1 {
    font-size: var(--text-display-lg);
    line-height: var(--leading-tight);
    margin: var(--space-4) 0 var(--space-4);
  }

  .byline {
    font-size: var(--text-tag);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }
  .byline a { color: var(--color-text); text-decoration: none; }
  .byline a:hover { color: var(--color-accent); }

  /* Standfirst: clearly below the H1, not competing with it. */
  .standfirst {
    font-family: var(--font-display);
    font-size: var(--text-lead);
    line-height: var(--leading-snug, 1.35);
    color: var(--color-text-muted);
    margin: 0;
    max-width: var(--measure);
  }

  /* Full-bleed banner: the images are landscape, so let them run edge to edge
     regardless of the container padding. */
  .post-banner {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin: var(--space-7) -50vw;
  }
  .post-banner img {
    width: 100%;
    height: auto;
    max-height: 70vh;
    object-fit: cover;
    display: block;
  }

  /* --- Article body ------------------------------------------------------- */
  .prose :global(img) {
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: var(--space-5) 0;
    border-radius: var(--radius);
  }

  /* Heading hierarchy: H1 is the big title; in-article headings step down
     clearly from it. */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--size-2xl);
    line-height: var(--leading-tight);
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--text-h2);
    line-height: var(--leading-tight);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }
  .prose :global(h4) {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    margin-top: var(--space-5);
    margin-bottom: var(--space-2);
  }

  /* Image captions: small, muted and centred, so they read as a caption
     rather than body copy. Pull the caption up tight under its image. */
  .prose :global(.post-caption) {
    margin: var(--space-2) 0 var(--space-6);
    font-size: var(--text-body-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    text-align: center;
  }
  .prose :global(p:has(> img):has(+ .post-caption)) {
    margin-bottom: 0;
  }

  /* Embedded video (a one-off on the founders' post): full width with native
     controls. */
  .prose :global(.post-video) {
    margin: var(--space-6) 0;
  }
  .prose :global(.post-video video) {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    display: block;
    border-radius: var(--radius);
    background: #000;
  }

  /* Pull quotes: set apart from the (serif, upright) section headings with an
     italic face inside a tinted panel and a coral rule. */
  .prose :global(blockquote) {
    margin: var(--space-7) 0;
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface-muted);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular, 400);
    font-size: var(--size-2xl);
    line-height: var(--leading-snug, 1.3);
    color: var(--color-text);
  }
  .prose :global(blockquote p) {
    margin: 0 0 var(--space-3);
  }
  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  /* A long, multi-paragraph quotation (e.g. quoting a paper) is not a pull-out
     quote: render it smaller and without the panel, so it reads as a citation. */
  .prose :global(blockquote:has(p + p)) {
    background: none;
    border-radius: 0;
    padding: var(--space-1) 0 var(--space-1) var(--space-5);
    font-size: var(--text-lead);
    line-height: var(--leading-normal);
  }
</style>
