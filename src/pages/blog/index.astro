---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<Layout title="Blog" description="Thinking, learning and stories from the Brink team.">
  <div class="container">
    <header class="page-header">
      <h1>Blog</h1>
      <p>Thinking, learning and stories from the Brink team.</p>
    </header>

    <ul class="post-grid">
      {posts.map((post) => {
        const authors = [post.data.authorName, post.data.authorName2].filter(Boolean).join(' & ');
        return (
          <li class="post">
            <a href={withBase(`/blog/${post.id}`)}>
              {post.data.heroImage && (
                <img src={withBase(post.data.heroImage)} alt={post.data.heroAlt ?? post.data.title} loading="lazy" />
              )}
              <div class="post-body">
                <h2>{post.data.title}</h2>
                {post.data.subheading && <p class="subheading">{post.data.subheading}</p>}
                {authors && <p class="author">{authors}</p>}
              </div>
            </a>
          </li>
        );
      })}
    </ul>

    <p class="archive-note">
      Older posts are still on the
      <a href="https://www.hellobrink.co/blog" target="_blank" rel="noopener">previous site</a>.
    </p>
  </div>
</Layout>

<style>
  .page-header {
    padding: var(--space-6) 0 var(--space-5);
    max-width: var(--measure);
  }

  .post-grid {
    list-style: none;
    margin: 0 0 var(--space-6);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .post a {
    display: block;
    height: 100%;
    text-decoration: none;
    color: var(--color-text);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  /* Square thumbnail: the CMS thumbnail images are square, so they sit tidily
     in the card without heavy cropping. */
  .post img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }

  .post-body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .post h2 {
    font-size: var(--text-h3);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .post a:hover h2 {
    color: var(--color-accent);
  }

  .subheading {
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: var(--leading-normal);
  }

  .author {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-label);
    margin: 0;
  }

  .archive-note {
    color: var(--color-text-muted);
    font-size: var(--text-body-sm);
    margin-bottom: var(--space-9);
  }
</style>
