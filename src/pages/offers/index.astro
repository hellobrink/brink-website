---
// Our offers, on one page.
//
// Each offer is a full-bleed colour banner (number, title, subheading, and the
// offer's badge once as a section emblem) followed by an editorial body:
//   - the intro split into a large lead statement beside supporting paragraphs
//   - each group a colour heading over a flowing, borderless list (hairline
//     rules, balanced across two columns) so varied item lengths and odd
//     counts read as intentional rather than as hollow boxes.
// Deliberately NOT a uniform grid of icon-boxes: hierarchy comes from
// typography and one section emblem, not repeated identical chrome.
import Layout from '../../layouts/Layout.astro';
import ExploreCTA from '../../components/ExploreCTA.astro';
import { withBase } from '../../lib/base';
import { getCollection } from 'astro:content';

const offers = await getCollection('offers');
const order = ['open-innovation', 'carve-outs', 'missions'];
offers.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));

const allWork = await getCollection('work');
const relatedFor = (id: string) =>
  allWork
    .filter((w) => w.data.offer.includes(id))
    .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

// Inline Markdown -> HTML for the copy that carries links and bold. Escapes
// first: the content is not trusted markup.
const inline = (s: string) =>
  s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g,
      '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*\*/g, '');
---

<Layout
  title="Our offers"
  description="How Brink works: Open Innovation, Innovation Carve-Outs and Innovation Missions."
>
  <div class="container">
    <header class="page-header">
      <p class="mono kicker">Our offers</p>
      <h1 class="display">Three ways we build funds and back innovation</h1>
      <p class="page-intro">
        Our work brings behavioural approaches to tried and trusted innovation
        methods. Below are our three core approaches, each addressing a
        different stage and type of systemic challenge.
      </p>
    </header>
  </div>

  {offers.map((offer, i) => {
    const { data } = offer;
    const related = relatedFor(offer.id);
    return (
      <section class:list={['offer', `ground-${data.ground}`]} id={offer.id}>
        <div class="offer-banner">
          <div class="banner-inner container">
            <div class="banner-head">
              <p class="banner-num mono">{String(i + 1).padStart(2, '0')}</p>
              <h2 class="display banner-title">{data.name}</h2>
              <p class="banner-subhead">{data.summary}</p>
            </div>
            {data.image && (
              <div class="banner-emblem">
                <img src={withBase(data.image)} alt={data.imageAlt ?? ''} loading="lazy" />
              </div>
            )}
          </div>
        </div>

        <div class="offer-body container">
          {(data.lead || data.intro.length > 0) && (
            <div class="intro">
              {data.lead && <p class="intro-lead">{data.lead}</p>}
              {data.intro.length > 0 && (
                <div class="intro-body">
                  {data.intro.map((p) => <p>{p}</p>)}
                </div>
              )}
            </div>
          )}

          {data.groups.map((group) => (
            <section class="group">
              <h3 class="group-lead" set:html={inline(group.lead)} />
              <ul class="group-items">
                {group.items.map((item) => (
                  <li class="group-item" set:html={inline(item)} />
                ))}
              </ul>
            </section>
          ))}

          {data.note && <p class="note" set:html={inline(data.note)} />}

          {related.length > 0 && (
            <nav class="related" aria-label={`Work using ${data.name}`}>
              <p class="related-label mono">Related work</p>
              <ul>
                {related.map((w) => (
                  <li><a href={withBase(`/our-work/${w.id}`)}>{w.data.title}</a></li>
                ))}
              </ul>
            </nav>
          )}
        </div>
      </section>
    );
  })}

  <ExploreCTA />
</Layout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-7);
    max-width: var(--measure);
  }

  .kicker {
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
    margin: 0 0 var(--space-3);
  }

  h1.display {
    font-size: var(--text-display);
    margin: 0 0 var(--space-4);
    line-height: var(--leading-tight);
  }

  .page-intro {
    font-size: var(--text-lead);
    max-width: var(--measure-narrow);
    margin: 0;
    color: var(--color-text-muted);
  }

  /* Each offer takes its brand colour as a local variable, used by the banner
     and the group headings so the module reads as one colour identity. */
  .offer { scroll-margin-top: var(--space-6); }
  .ground-teal  { --offer-ink: var(--color-ground-1); }
  .ground-coral { --offer-ink: var(--color-ground-3); }
  .ground-blue  { --offer-ink: var(--color-ground-2); }

  /* --- Banner ------------------------------------------------------------- */
  .offer-banner {
    background: var(--offer-ink);
    color: var(--color-text-inverted, #fff);
    padding: var(--space-8) 0;
  }

  .banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .banner-num {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    opacity: 0.85;
    margin: 0 0 var(--space-2);
  }

  .banner-title {
    font-size: var(--text-display);
    color: inherit;
    margin: 0 0 var(--space-3);
    line-height: var(--leading-tight);
  }

  .banner-subhead {
    /* Large text (>=24px) so white-on-colour clears AA's 3:1 on coral/blue. */
    font-size: var(--size-2xl);
    font-family: var(--font-display);
    color: inherit;
    opacity: 0.95;
    margin: 0;
    max-width: 32ch;
    line-height: var(--leading-snug, 1.3);
  }

  /* The badge sits in a white disc so the dark sticker reads on any ground.
     Used once per offer as a section emblem, never repeated per point. */
  .banner-emblem {
    flex-shrink: 0;
    width: 7rem;
    height: 7rem;
    border-radius: 50%;
    background: var(--color-surface);
    display: grid;
    place-items: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
  }
  .banner-emblem img {
    width: 62%;
    height: 62%;
    object-fit: contain;
    display: block;
  }

  /* --- Body --------------------------------------------------------------- */
  .offer-body {
    padding: var(--space-8) 0 var(--space-9);
  }

  /* Intro: a lead statement beside its supporting paragraphs. The left column
     carries real weight (the statement), so there's no empty gutter. */
  .intro {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: var(--space-6) var(--space-8);
    align-items: start;
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }

  .intro-lead {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--size-2xl);
    line-height: var(--leading-snug, 1.3);
    color: var(--color-text);
    margin: 0;
  }

  .intro-body {
    max-width: var(--measure);
  }
  .intro-body p {
    margin: 0 0 var(--space-4);
    line-height: var(--leading-normal);
  }
  .intro-body p:last-child { margin-bottom: 0; }

  /* Groups: a colour heading over a flowing borderless list. Two balanced
     columns; items keep their natural height and are separated by hairlines,
     so a short item and a long one sit together without forced box heights,
     and an odd count never leaves a hollow slot. */
  .group {
    padding-top: var(--space-7);
  }

  .group-lead {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--size-2xl);
    line-height: var(--leading-tight);
    color: var(--offer-ink);
    margin: 0 0 var(--space-4);
    max-width: 40ch;
  }

  .group-items {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 2;
    column-gap: var(--space-8);
  }

  .group-item {
    break-inside: avoid;
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
    line-height: var(--leading-normal);
  }
  .group-item:first-child { border-top: 0; padding-top: var(--space-2); }

  /* Emphasise the named programme (the link) so entries are scannable. */
  .group-item :global(a) {
    font-weight: var(--weight-bold);
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--offer-ink);
  }
  .group-item :global(a:hover) { color: var(--offer-ink); }

  .note {
    margin: var(--space-6) 0 0;
    font-size: var(--text-body-sm);
  }
  .note :global(a) { color: var(--color-accent); }

  /* --- Related work ------------------------------------------------------- */
  .related {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .related-label {
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }
  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }
  .related a {
    display: inline-block;
    font-size: var(--text-body-sm);
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    padding: var(--space-2) var(--space-3);
    line-height: var(--leading-tight);
  }
  .related a:hover { border-color: var(--offer-ink); color: var(--offer-ink); }

  @media (max-width: 820px) {
    .banner-emblem { width: 5rem; height: 5rem; }
    .banner-subhead { max-width: none; }
  }

  @media (max-width: 680px) {
    .banner-emblem { display: none; }
    .intro { grid-template-columns: 1fr; }
    .group-items { columns: 1; }
    .offer-banner { padding: var(--space-7) 0; }
  }
</style>
