---
// Our offers, on one page.
//
// Replaces the old interstitial grid + three thin detail pages. Modelled on
// fundinnovation.dev/approach, which puts the whole proposition on a single
// scroll with a strong internal rhythm: hero -> numbered blocks, each with the
// same internal shape -> CTA. Here the three offers become three numbered
// bands that alternate the illustration side, each on its own brand ground,
// with the full descriptive copy (and its real programme links) rendered in
// place rather than hidden behind a click.
import Layout from '../../layouts/Layout.astro';
import ExploreCTA from '../../components/ExploreCTA.astro';
import { withBase } from '../../lib/base';
import { getCollection, render } from 'astro:content';

const offers = await getCollection('offers');
const order = ['open-innovation', 'carve-outs', 'missions'];
offers.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));

// Illustration + ground per offer, matched to meaning rather than assigned at
// random (see the old grid's note): the rowing crew pulling together for Open
// Innovation's many teams, ideas taking flight for Carve-Outs, the climber —
// the one Brink already pairs with "a bold, long-term vision" — for Missions.
// Grounds are fixed to each illustration, never rotated: the cranes artwork
// has coral baked in and would clash on any other ground.
const artwork: Record<
  string,
  { image: string; alt: string; focus?: string; ground: 'teal' | 'blue' | 'coral' }
> = {
  'open-innovation': {
    image: '/images/illo-row.png',
    alt: 'A rowing crew pulling together through choppy water, torn from the page',
    ground: 'teal',
  },
  'carve-outs': {
    image: '/images/illo-cranes.png',
    alt: 'A woman deep in thought as origami cranes take flight from her opened mind',
    focus: '86% center',
    ground: 'coral',
  },
  missions: {
    image: '/images/illo-climber.png',
    alt: 'A climber scaling the torn edge of the page as if it were a rock face',
    ground: 'blue',
  },
};

const allWork = await getCollection('work');

// Render each offer's Markdown in place, and gather its related programmes by
// tag so the reader can jump straight from an approach to the work that used
// it.
const bands = await Promise.all(
  offers.map(async (offer) => ({
    offer,
    art: artwork[offer.id],
    Content: (await render(offer)).Content,
    related: allWork
      .filter((w) => w.data.offer.includes(offer.id))
      .sort((a, b) => a.data.sortOrder - b.data.sortOrder),
  }))
);
---

<Layout
  title="Our offers"
  description="How Brink works: Open Innovation, Innovation Carve-Outs and Innovation Missions."
>
  <div class="container">
    <header class="page-header">
      <p class="mono kicker">Our offers</p>
      <h1 class="display">Three ways we build funds and back innovation</h1>
      <p class="page-intro">
        Our work brings behavioural approaches to tried and trusted innovation
        methods. Below are our three core approaches, each addressing a
        different stage and type of systemic challenge.
      </p>
    </header>
  </div>

  {bands.map(({ offer, art, Content, related }, i) => (
    <section class="offer-band" id={offer.id}>
      <div class="container band-inner">
        <div class:list={['band-media', `ground-${art.ground}`]}>
          <img
            src={withBase(art.image)}
            alt={art.alt}
            style={art.focus ? `object-position: ${art.focus}` : undefined}
            loading="lazy"
          />
        </div>
        <div class="band-body">
          <p class="band-num mono">{String(i + 1).padStart(2, '0')}</p>
          <h2 class="display band-title">{offer.data.name}</h2>
          <p class="band-summary">{offer.data.summary}</p>
          <div class="prose offer-prose"><Content /></div>

          {related.length > 0 && (
            <nav class="related-programmes" aria-label={`Work using ${offer.data.name}`}>
              <p class="related-label mono">Related work</p>
              <ul>
                {related.map((w) => (
                  <li>
                    <a href={withBase(`/our-work/${w.id}`)}>{w.data.title}</a>
                  </li>
                ))}
              </ul>
            </nav>
          )}
        </div>
      </div>
    </section>
  ))}

  <ExploreCTA />
</Layout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--measure);
  }

  .kicker {
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
    margin: 0 0 var(--space-3);
  }

  h1.display {
    font-size: var(--text-display);
    margin: 0 0 var(--space-4);
    line-height: var(--leading-tight);
  }

  .page-intro {
    font-size: var(--text-lead);
    max-width: var(--measure-narrow);
    margin: 0;
    color: var(--color-text-muted);
  }

  /* --- The numbered bands ------------------------------------------------- */
  .offer-band {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    scroll-margin-top: var(--space-8);
  }

  .band-inner {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-7);
    align-items: start;
  }

  /* Alternate the illustration side so the page has rhythm rather than a
     single stacked column. The media is column 1 by default; on even bands it
     moves to column 2 and the body takes column 1. */
  .offer-band:nth-child(even) .band-media {
    grid-column: 2;
    grid-row: 1;
  }
  .offer-band:nth-child(even) .band-body {
    grid-column: 1;
    grid-row: 1;
  }

  /* The illustration sits on its brand ground; the transparent parts of the
     PNG let the colour show through, and the torn kraft edge is the point
     (brand book §06). Pinned near the top so it tracks the copy on long bands. */
  .band-media {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    position: sticky;
    top: var(--space-6);
  }

  .ground-teal { background: var(--color-ground-1); }
  .ground-blue { background: var(--color-ground-2); }
  .ground-coral { background: var(--color-ground-3); }

  .band-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .band-num {
    font-size: var(--text-h3);
    color: var(--color-accent);
    margin: 0 0 var(--space-2);
  }

  .band-title {
    font-size: var(--text-h1);
    margin: 0 0 var(--space-3);
    line-height: var(--leading-tight);
  }

  .band-summary {
    font-size: var(--text-lead);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
    max-width: var(--measure);
  }

  .offer-prose {
    max-width: var(--measure);
  }

  /* The Markdown carries "Brink specialises in ... through:" lead-ins followed
     by bulleted example programmes with links. Give the lists room and mark
     the bullets in brand style. */
  .offer-prose :global(p) {
    margin: 0 0 var(--space-4);
  }

  .offer-prose :global(ul) {
    list-style: none;
    margin: 0 0 var(--space-5);
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }

  .offer-prose :global(li) {
    position: relative;
    padding-left: var(--space-5);
    line-height: var(--leading-normal);
  }

  .offer-prose :global(li)::before {
    content: '\203A'; /* › */
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  .offer-prose :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--color-accent);
  }

  .offer-prose :global(a:hover) {
    color: var(--color-accent);
  }

  /* --- Related programmes ------------------------------------------------- */
  .related-programmes {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .related-label {
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  .related-programmes ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  .related-programmes a {
    display: inline-block;
    font-size: var(--text-body-sm);
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    padding: var(--space-2) var(--space-3);
    line-height: var(--leading-tight);
  }

  .related-programmes a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 820px) {
    .band-inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    /* Stack with the illustration on top on every band, whatever the desktop
       side. */
    .offer-band:nth-child(even) .band-media,
    .offer-band:nth-child(even) .band-body {
      grid-column: 1;
    }
    .band-media {
      position: static;
      aspect-ratio: 16 / 10;
      max-height: 22rem;
    }
  }
</style>
