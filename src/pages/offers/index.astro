---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { getCollection } from 'astro:content';
import ExploreCTA from '../../components/ExploreCTA.astro';
import IllustratedGrid from '../../components/IllustratedGrid.astro';

const offers = await getCollection('offers');
const order = ['open-innovation', 'carve-outs', 'missions'];
offers.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));

// Illustration per offer, matched to meaning rather than assigned at random:
// a rowing crew pulling together for Open Innovation's many teams; ideas
// taking flight out of an opened mind for Carve-Outs; and the climber — the
// one Brink already pairs with "a bold, long-term vision" — for Missions.
//
// `focus` picks what survives the crop. The cranes image is a 2.47 banner
// with its subject hard right, so it needs pushing right; the two portrait
// illustrations sit fine centred.
// Grounds are assigned per illustration, not rotated: the cranes artwork has
// coral baked into it and would clash against any other ground, and Brink
// itself pairs the climber with draft blue on bi.hellobrink.co.
const artwork: Record<
  string,
  { image: string; alt: string; focus?: string; ground: 'teal' | 'blue' | 'coral' }
> = {
  'open-innovation': {
    image: '/images/illo-row.png',
    alt: 'A rowing crew pulling together through choppy water, torn from the page',
    ground: 'teal',
  },
  'carve-outs': {
    image: '/images/illo-cranes.png',
    alt: 'A woman deep in thought as origami cranes take flight from her opened mind',
    focus: '86% center',
    ground: 'coral',
  },
  missions: {
    image: '/images/illo-climber.png',
    alt: 'A climber scaling the torn edge of the page as if it were a rock face',
    ground: 'blue',
  },
};

const offerItems = offers.map((offer) => ({
  title: offer.data.name,
  summary: offer.data.summary,
  href: withBase(`/offers/${offer.id}`),
  ...artwork[offer.id],
}));
---

<Layout title="Our Offers" description="How Brink works: Open Innovation, Innovation Carve-Outs and Innovation Missions.">
  <div class="container">
    <header class="page-header">
      <h1>Our offers</h1>
      <p class="page-intro">
        Our work brings behavioural approaches to tried and trusted innovation
        methods. On this page you&rsquo;ll find details of our three core
        approaches, each of which address different stages and types of
        systemic challenges.
      </p>
    </header>
  </div>

  <IllustratedGrid items={offerItems} />

  <ExploreCTA />
</Layout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-4);
  }

  .page-intro {
    font-size: var(--text-lead);
    max-width: var(--measure-narrow);
    margin: var(--space-4) 0 0;
  }

  .offers-grid {
    list-style: none;
    margin: 0 0 var(--space-9);
    padding: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .offers-grid a {
    display: block;
    height: 100%;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    border-radius: var(--radius);
    padding: var(--space-5);
    border: var(--border-width) solid var(--color-border);
  }

  .offers-grid a:hover h2 {
    color: var(--color-accent);
  }

  .offers-grid p {
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
