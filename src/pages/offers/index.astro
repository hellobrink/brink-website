---
// Our offers, on one page.
//
// Each offer is a full-bleed colour banner (number, title, subheading)
// followed by an editorial body built for white space and rhythm:
//   - the intro as a large lead statement, with the supporting paragraphs
//     dropped down and offset on the right
//   - the two point-groups alternated: the first sits on the left, the second
//     is offset to the right, each a heading over a plain bullet list.
// No per-item icons and no hairline rules: hierarchy comes from type, position
// and white space. Headings stay dark (coloured headings fought the links).
import Layout from '../../layouts/Layout.astro';
import ExploreCTA from '../../components/ExploreCTA.astro';
import { withBase } from '../../lib/base';
import { getCollection } from 'astro:content';

const offers = await getCollection('offers');
const order = ['open-innovation', 'carve-outs', 'missions'];
offers.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));

const allWork = await getCollection('work');
const relatedFor = (id: string) =>
  allWork
    .filter((w) => w.data.offer.includes(id))
    .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

// Inline Markdown -> HTML for copy that carries links and bold. Escapes first:
// the content is not trusted markup.
const inline = (s: string) =>
  s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g,
      '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*\*/g, '');
---

<Layout
  title="Our offers"
  description="How Brink works: Open Innovation, Innovation Carve-Outs and Innovation Missions."
>
  <div class="container">
    <header class="page-header">
      <p class="mono kicker">Our offers</p>
      <h1 class="display">Three ways we build funds and back innovation</h1>
      <p class="page-intro">
        Our work brings behavioural approaches to tried and trusted innovation
        methods. Below are our three core approaches, each addressing a
        different stage and type of systemic challenge.
      </p>
    </header>
  </div>

  {offers.map((offer, i) => {
    const { data } = offer;
    const related = relatedFor(offer.id);
    return (
      <section class:list={['offer', `ground-${data.ground}`]} id={offer.id}>
        <div class="offer-banner">
          <div class="banner-inner container">
            <p class="banner-num mono">{String(i + 1).padStart(2, '0')}</p>
            <h2 class="display banner-title">{data.name}</h2>
            <p class="banner-subhead">{data.summary}</p>
          </div>
        </div>

        <div class="offer-body container">
          {(data.lead || data.intro.length > 0) && (
            <div class="intro">
              {data.lead && <p class="intro-lead">{data.lead}</p>}
              {data.intro.length > 0 && (
                <div class="intro-body">
                  {data.intro.map((p) => <p>{p}</p>)}
                </div>
              )}
            </div>
          )}

          {data.groups.map((group, gi) => (
            <section class:list={['group', gi % 2 === 0 ? 'left' : 'right']}>
              <h3 class="group-lead" set:html={inline(group.lead)} />
              <ul class="bullets">
                {group.items.map((item) => (
                  <li set:html={inline(item)} />
                ))}
              </ul>
            </section>
          ))}

          {data.note && <p class="note" set:html={inline(data.note)} />}

          {related.length > 0 && (
            <nav class="related" aria-label={`Work using ${data.name}`}>
              <p class="related-label mono">Related work</p>
              <ul>
                {related.map((w) => (
                  <li><a href={withBase(`/our-work/${w.id}`)}>{w.data.title}</a></li>
                ))}
              </ul>
            </nav>
          )}
        </div>
      </section>
    );
  })}

  <ExploreCTA />
</Layout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-7);
    max-width: var(--measure);
  }

  .kicker {
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
    margin: 0 0 var(--space-3);
  }

  h1.display {
    font-size: var(--text-display);
    margin: 0 0 var(--space-4);
    line-height: var(--leading-tight);
  }

  .page-intro {
    font-size: var(--text-lead);
    max-width: var(--measure-narrow);
    margin: 0;
    color: var(--color-text-muted);
  }

  .offer { scroll-margin-top: var(--space-6); }
  .ground-teal  { --offer-ink: var(--color-ground-1); }
  .ground-coral { --offer-ink: var(--color-ground-3); }
  .ground-blue  { --offer-ink: var(--color-ground-2); }

  /* --- Banner ------------------------------------------------------------- */
  .offer-banner {
    background: var(--offer-ink);
    color: var(--color-text-inverted, #fff);
    padding: var(--space-8) 0;
  }

  .banner-num {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    opacity: 0.85;
    margin: 0 0 var(--space-2);
  }

  .banner-title {
    font-size: var(--text-display);
    color: inherit;
    margin: 0 0 var(--space-3);
    line-height: var(--leading-tight);
  }

  .banner-subhead {
    /* Large text (>=24px) so white-on-colour clears AA's 3:1 on coral/blue. */
    font-size: var(--size-2xl);
    font-family: var(--font-display);
    color: inherit;
    opacity: 0.95;
    margin: 0;
    max-width: 32ch;
    line-height: var(--leading-snug, 1.3);
  }

  /* --- Body --------------------------------------------------------------- */
  .offer-body {
    padding: var(--space-8) 0 var(--space-9);
  }

  /* Intro: a big lead statement, with the supporting paragraphs dropped down
     and offset on the right so it doesn't read as one solid block. */
  .intro {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: var(--space-8);
    align-items: start;
  }

  .intro-lead {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--size-2xl);
    line-height: var(--leading-snug, 1.3);
    color: var(--color-text);
    margin: 0;
  }

  .intro-body {
    max-width: var(--measure);
    /* Drop the sub-paragraphs well down the lead so the page steps: lead
       (upper left) -> sub-paragraphs (lower right) -> group 1 (left) ->
       group 2 (right). */
    margin-top: clamp(3rem, 8vw, 7rem);
  }
  .intro-body p {
    margin: 0 0 var(--space-4);
    line-height: var(--leading-normal);
  }
  .intro-body p:last-child { margin-bottom: 0; }

  /* Point-groups: alternated for rhythm and white space. The first sits on the
     left; the second is offset to the right. Each is a heading over a plain
     bullet list, at a comfortable half-width measure. */
  .group {
    max-width: 40rem;
    margin-top: var(--space-9);
  }
  /* Pushed to the right, but text stays left-aligned for readability. */
  .group.right {
    margin-left: auto;
  }

  .group-lead {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--size-2xl);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin: 0 0 var(--space-5);
  }

  .bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .bullets li {
    position: relative;
    padding-left: var(--space-5);
    line-height: var(--leading-normal);
  }
  .bullets li::before {
    content: '\203A'; /* › */
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  /* Links consistent across every module: dark text, coral underline. */
  .bullets :global(a),
  .note :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-accent);
    font-weight: var(--weight-bold);
  }
  .bullets :global(a:hover),
  .note :global(a:hover) { color: var(--color-accent); }

  .note {
    margin: var(--space-7) 0 0;
    font-size: var(--text-body-sm);
  }
  .note :global(a) { font-weight: var(--weight-regular, 400); }

  /* --- Related work ------------------------------------------------------- */
  .related {
    margin-top: var(--space-9);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .related-label {
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }
  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }
  .related a {
    display: inline-block;
    font-size: var(--text-body-sm);
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    padding: var(--space-2) var(--space-3);
    line-height: var(--leading-tight);
  }
  .related a:hover { border-color: var(--color-accent); color: var(--color-accent); }

  @media (max-width: 820px) {
    .banner-subhead { max-width: none; }
  }

  @media (max-width: 680px) {
    .intro { grid-template-columns: 1fr; gap: var(--space-5); }
    .intro-body { margin-top: 0; }
    .group { max-width: none; margin-top: var(--space-7); }
    .group.right .group-lead { text-align: left; }
    .offer-banner { padding: var(--space-7) 0; }
  }
</style>
