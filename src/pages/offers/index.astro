---
// Our offers, on one page.
//
// Replaces the old interstitial grid + three thin detail pages. Modelled on
// fundinnovation.dev/approach: the whole proposition on a single scroll with a
// strong internal rhythm. Here the three offers are three full-bleed brand
// bands (teal / coral / blue), each with the illustration bleeding on one
// side and the copy on a floating off-white card on the other.
//
// Why a card rather than text straight on the colour: these bands are
// body-heavy (paragraphs, bulleted programme lists, links) and only teal
// carries small text at WCAG AA. White on coral is ~3:1 and on draft blue
// ~3.8:1, both large-text-only (brand book §, and the note in CLAUDE.md). So
// the colour and illustration do the full-bleed drama; the card keeps the
// copy legible. The card alternates sides to give the page its rhythm.
import Layout from '../../layouts/Layout.astro';
import ExploreCTA from '../../components/ExploreCTA.astro';
import { withBase } from '../../lib/base';
import { getCollection, render } from 'astro:content';

const offers = await getCollection('offers');
const order = ['open-innovation', 'carve-outs', 'missions'];
offers.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));

// Illustration + ground per offer, matched to meaning rather than assigned at
// random: the rowing crew pulling together for Open Innovation's many teams,
// ideas taking flight for Carve-Outs, the climber — the one Brink already
// pairs with "a bold, long-term vision" — for Missions. Grounds are fixed to
// each illustration, never rotated: the cranes artwork has coral baked in.
const artwork: Record<
  string,
  { image: string; alt: string; focus?: string; ground: 'teal' | 'blue' | 'coral' }
> = {
  'open-innovation': {
    image: '/images/illo-row.png',
    alt: 'A rowing crew pulling together through choppy water, torn from the page',
    ground: 'teal',
  },
  'carve-outs': {
    image: '/images/illo-cranes.png',
    alt: 'A woman deep in thought as origami cranes take flight from her opened mind',
    focus: '86% center',
    ground: 'coral',
  },
  missions: {
    image: '/images/illo-climber.png',
    alt: 'A climber scaling the torn edge of the page as if it were a rock face',
    ground: 'blue',
  },
};

const allWork = await getCollection('work');

// Render each offer's Markdown in place, and gather its related programmes by
// tag so the reader can jump straight from an approach to the work that used it.
const bands = await Promise.all(
  offers.map(async (offer) => ({
    offer,
    art: artwork[offer.id],
    Content: (await render(offer)).Content,
    related: allWork
      .filter((w) => w.data.offer.includes(offer.id))
      .sort((a, b) => a.data.sortOrder - b.data.sortOrder),
  }))
);
---

<Layout
  title="Our offers"
  description="How Brink works: Open Innovation, Innovation Carve-Outs and Innovation Missions."
>
  <div class="container">
    <header class="page-header">
      <p class="mono kicker">Our offers</p>
      <h1 class="display">Three ways we build funds and back innovation</h1>
      <p class="page-intro">
        Our work brings behavioural approaches to tried and trusted innovation
        methods. Below are our three core approaches, each addressing a
        different stage and type of systemic challenge.
      </p>
    </header>
  </div>

  {bands.map(({ offer, art, Content, related }, i) => (
    <section class:list={['offer', `ground-${art.ground}`]} id={offer.id}>
      {/* Colour banner: number + title in white beside the illustration in a
          bounded landscape box, so nothing stretches tall. Only large text
          sits on the colour. */}
      <div class="offer-banner">
        <div class="banner-inner container">
          <div class="banner-head">
            <p class="banner-num mono">{String(i + 1).padStart(2, '0')}</p>
            <h2 class="display banner-title">{offer.data.name}</h2>
          </div>
          <div class="banner-art">
            <img
              src={withBase(art.image)}
              alt={art.alt}
              style={art.focus ? `object-position: ${art.focus}` : undefined}
              loading="lazy"
            />
          </div>
        </div>
      </div>

      {/* Body: full-width single reading column on white. */}
      <div class="offer-body container">
        <div class="offer-body-inner">
          <p class="offer-summary">{offer.data.summary}</p>
          <div class="prose offer-prose"><Content /></div>

          {related.length > 0 && (
            <nav class="related-programmes" aria-label={`Work using ${offer.data.name}`}>
              <p class="related-label mono">Related work</p>
              <ul>
                {related.map((w) => (
                  <li>
                    <a href={withBase(`/our-work/${w.id}`)}>{w.data.title}</a>
                  </li>
                ))}
              </ul>
            </nav>
          )}
        </div>
      </div>
    </section>
  ))}

  <ExploreCTA />
</Layout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-7);
    max-width: var(--measure);
  }

  .kicker {
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
    margin: 0 0 var(--space-3);
  }

  h1.display {
    font-size: var(--text-display);
    margin: 0 0 var(--space-4);
    line-height: var(--leading-tight);
  }

  .page-intro {
    font-size: var(--text-lead);
    max-width: var(--measure-narrow);
    margin: 0;
    color: var(--color-text-muted);
  }

  /* --- Offer sections ----------------------------------------------------- */
  /* Each offer is a short full-bleed colour banner (number + title beside a
     bounded landscape illustration) followed by a full-width reading column on
     white. Only the large banner title sits on the colour, which is the one
     size that clears WCAG AA on coral and draft blue; all body copy stays on
     white so it keeps ~13:1. */
  .offer {
    scroll-margin-top: var(--space-6);
  }

  .ground-teal .offer-banner { background: var(--color-ground-1); }
  .ground-blue .offer-banner { background: var(--color-ground-2); }
  .ground-coral .offer-banner { background: var(--color-ground-3); }

  .offer-banner {
    padding: var(--space-7) 0;
  }

  .banner-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  /* Alternate the illustration side for rhythm: art is column 2 by default,
     column 1 on every second offer. */
  .offer:nth-of-type(even) .banner-art {
    grid-column: 1;
    grid-row: 1;
  }
  .offer:nth-of-type(even) .banner-head {
    grid-column: 2;
    grid-row: 1;
  }

  .banner-head {
    color: var(--color-text-inverted, #fff);
  }

  .banner-num {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    opacity: 0.85;
    margin: 0 0 var(--space-2);
  }

  .banner-title {
    font-size: var(--text-display);
    color: inherit;
    margin: 0 0 var(--space-3);
    line-height: var(--leading-tight);
  }

  /* Bounded landscape box so no illustration stretches tall/thin; the torn
     transparent edge lets the banner colour show through. */
  .banner-art {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: var(--radius);
  }

  .banner-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* --- Body: one comfortable reading column ------------------------------- */
  .offer-body {
    padding: var(--space-8) 0 var(--space-9);
  }

  .offer-body-inner {
    max-width: var(--measure);
  }

  .offer-summary {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: var(--leading-snug, 1.3);
    color: var(--color-text);
    margin: 0 0 var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .offer-prose {
    max-width: var(--measure);
  }

  /* The Markdown carries "Brink specialises in ... through:" lead-ins followed
     by bulleted example programmes with links. Give the lists room and mark
     the bullets in brand style. */
  .offer-prose :global(p) {
    margin: 0 0 var(--space-4);
  }

  .offer-prose :global(ul) {
    list-style: none;
    margin: 0 0 var(--space-5);
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }

  .offer-prose :global(li) {
    position: relative;
    padding-left: var(--space-5);
    line-height: var(--leading-normal);
  }

  .offer-prose :global(li)::before {
    content: '\203A'; /* › */
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  .offer-prose :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--color-accent);
  }

  .offer-prose :global(a:hover) {
    color: var(--color-accent);
  }

  /* --- Related programmes ------------------------------------------------- */
  .related-programmes {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .related-label {
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  .related-programmes ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  .related-programmes a {
    display: inline-block;
    font-size: var(--text-body-sm);
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    padding: var(--space-2) var(--space-3);
    line-height: var(--leading-tight);
  }

  .related-programmes a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 820px) {
    .banner-inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    /* Title above the illustration on every offer, whatever the desktop side. */
    .offer:nth-of-type(even) .banner-head {
      grid-column: 1;
      grid-row: 1;
    }
    .offer:nth-of-type(even) .banner-art {
      grid-column: 1;
      grid-row: 2;
    }
    .banner-art {
      aspect-ratio: 16 / 10;
      max-height: 18rem;
    }
    .banner-summary {
      max-width: none;
    }
    .offer-body {
      padding: var(--space-6) 0 var(--space-8);
    }
  }
</style>
