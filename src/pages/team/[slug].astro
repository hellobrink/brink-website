---
// A single team bio.
//
// Three things restored from the live site: a much larger portrait, the
// "Questions X is exploring right now" block with its coral rule, and
// related posts shown as cards with thumbnails rather than a bare list of
// links.
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const members = await getCollection('team');
  return members.map((member) => ({
    params: { slug: member.id },
    props: { member },
  }));
}

const { member } = Astro.props;
const { Content } = await render(member);
const { data } = member;

const firstName = data.name.split(' ')[0];

// Posts this person wrote. The blog collection carries an authorSlug for
// exactly this.
const allPosts = await getCollection('blog');
const authored = allPosts
  .filter((p) => p.data.authorSlug === member.id)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<Layout title={data.name} description={`${data.name}${data.role ? `, ${data.role}` : ''} at Brink.`}>
  <article class="bio">
    <div class="container">
      <p class="back"><a href={withBase('/team')}>&larr; Meet the team</a></p>

      <header class="bio-header">
        {data.photo && (
          <span class="portrait">
            <img
              class="portrait-main"
              src={withBase(data.photo)}
              alt={data.photoAlt ?? data.name}
              fetchpriority="high"
            />
            {/* Same swap as the team grid, so the pair of portraits behaves
                consistently across both pages. */}
            {data.photoHover && (
              <img class="portrait-hover" src={withBase(data.photoHover)} alt="" aria-hidden="true" />
            )}
          </span>
        )}
        <div class="bio-meta">
          <h1 class="display">{data.name}</h1>
          {data.role && <p class="role mono">{data.role}</p>}
          {data.location && <p class="location">{data.location}</p>}
          {data.linkedin && (
            <p class="linkedin">
              <a href={data.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn &rarr;</a>
            </p>
          )}
        </div>
      </header>

      <div class="bio-body">
        <div class="prose">
          <Content />
        </div>

        {data.questions.length > 0 && (
          <section class="questions">
            <h2 class="display">Questions {firstName} is exploring in their work right now</h2>
            <ul>
              {data.questions.map((q) => <li>{q}</li>)}
            </ul>
          </section>
        )}
      </div>
    </div>

    {authored.length > 0 && (
      <section class="authored">
        <div class="container">
          <h2 class="display">{firstName}&rsquo;s writing</h2>
          <ul class="post-grid">
            {authored.map((post) => (
              <li>
                <a class="post-card" href={withBase(`/blog/${post.id}`)}>
                  {post.data.heroImage && (
                    <img
                      src={withBase(post.data.heroImage)}
                      alt={post.data.heroAlt ?? post.data.title}
                      loading="lazy"
                    />
                  )}
                  <h3>{post.data.title}</h3>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}
  </article>
</Layout>

<style>
  .bio {
    padding-top: var(--space-6);
    padding-bottom: var(--space-9);
  }

  .back a {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-label);
  }

  .back a:hover {
    color: var(--color-accent);
  }

  /* The portrait is the point of a bio page, so it gets real size rather
     than the thumbnail it had been reduced to. */
  .bio-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: center;
    margin: var(--space-6) 0 var(--space-8);
  }

  .portrait {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-surface-muted);
  }

  .portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portrait-hover {
    opacity: 0;
    transition: opacity var(--transition);
  }

  .portrait:hover .portrait-hover {
    opacity: 1;
  }

  .bio-header h1 {
    font-size: var(--text-display);
    margin: 0 0 var(--space-3);
  }

  .role {
    color: var(--color-accent);
    margin: 0 0 var(--space-2);
  }

  .location {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .linkedin a {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-label);
    text-decoration: none;
  }

  .linkedin a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .bio-body {
    max-width: var(--measure);
  }

  /* --- Questions ---------------------------------------------------------- */
  /* The coral rule above this block is how the live site marks it out, and
     it's the one moment of brand colour on an otherwise plain page. */
  .questions {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: var(--border-width-button) solid var(--color-accent);
  }

  .questions h2 {
    font-size: var(--text-h2);
    margin: 0 0 var(--space-5);
    max-width: var(--measure-narrow);
  }

  .questions ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .questions li {
    padding: var(--space-4) 0;
    border-bottom: var(--border-width) solid var(--color-border);
    font-size: var(--text-body);
  }

  .questions li:first-child {
    padding-top: 0;
  }

  /* --- Authored posts ----------------------------------------------------- */
  .authored {
    margin-top: var(--space-9);
    padding-top: var(--space-8);
    background: var(--color-surface-muted);
    padding-bottom: var(--space-8);
  }

  .authored h2 {
    font-size: var(--text-display);
    margin: 0 0 var(--space-6);
  }

  .post-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .post-card {
    display: block;
    text-decoration: none;
    color: var(--color-text);
  }

  .post-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: var(--space-3);
  }

  .post-card h3 {
    font-size: var(--text-h3);
    margin: 0;
  }

  .post-card:hover h3 {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .bio-header {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
