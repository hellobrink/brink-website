---
// A single team bio.
//
// Three things restored from the live site: a much larger portrait, the
// "Questions X is exploring right now" block with its coral rule, and
// related posts shown as cards with thumbnails rather than a bare list of
// links.
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const members = await getCollection('team');
  return members.map((member) => ({
    params: { slug: member.id },
    props: { member },
  }));
}

const { member } = Astro.props;
const { Content } = await render(member);
const { data } = member;

const firstName = data.name.split(' ')[0];

// Questions can carry Markdown links (some people linked words or the whole
// question out to a post or article). Render those safely: escape the text
// first, then turn [label](url) into anchors. Internal paths get the base
// path; external URLs open in a new tab.
const renderQuestion = (q: string): string =>
  q
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_m, label, url) => {
      const external = /^https?:/i.test(url);
      const href = external ? url : withBase(url);
      const attrs = external ? ' target="_blank" rel="noopener noreferrer"' : '';
      return `<a href="${href}"${attrs}>${label}</a>`;
    });

// Posts this person wrote. The blog collection carries an authorSlug for
// exactly this.
const allPosts = await getCollection('blog');
const authored = allPosts
  .filter((p) => p.data.authorSlug === member.id)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<Layout title={data.name} description={`${data.name}${data.role ? `, ${data.role}` : ''} at Brink.`}>
  <article class="bio">
    <div class="container">
      <p class="back"><a href={withBase('/team')}>&larr; Meet the team</a></p>

      <div class="bio-layout">
        {data.photo && (
          <span class="portrait">
            <img
              class="portrait-main"
              src={withBase(data.photo)}
              alt={data.photoAlt ?? data.name}
              fetchpriority="high"
            />
            {/* Same swap as the team grid, so the pair of portraits behaves
                consistently across both pages. */}
            {data.photoHover && (
              <img class="portrait-hover" src={withBase(data.photoHover)} alt="" aria-hidden="true" />
            )}
          </span>
        )}
        <div class="bio-main">
          <h1 class="display">{data.name}</h1>
          {/* The caret is the brand book's own list marker, used throughout
              its pages as a "&gt;" prefix. */}
          {data.role && (
            <p class="role mono"><span class="caret" aria-hidden="true">&gt;</span>{data.role}</p>
          )}
          {data.linkedin && (
            <a class="linkedin" href={data.linkedin} target="_blank" rel="noopener noreferrer"
               aria-label={`${data.name} on LinkedIn`}>
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.75V21h-4v-5.6c0-1.34-.03-3.06-1.9-3.06-1.9 0-2.2 1.45-2.2 2.96V21H9z"/>
              </svg>
            </a>
          )}
          <hr class="meta-rule" />
          {data.location && <p class="location">{data.location}</p>}

          {/* The bio copy continues in this same column, under the heading,
              rather than starting below the portrait. */}
          <div class="prose">
            <Content />
          </div>

          {data.questions.length > 0 && (
            <section class="questions">
              <h2 class="display">Questions {firstName} is exploring in their work right now</h2>
              <ul>
                {data.questions.map((q) => <li set:html={renderQuestion(q)} />)}
              </ul>
            </section>
          )}
        </div>
      </div>
    </div>

    {authored.length > 0 && (
      <section class="authored">
        <div class="container">
          <h2 class="display">{firstName}&rsquo;s writing</h2>
          <ul class="post-grid">
            {authored.map((post) => (
              <li>
                <a class="post-card" href={withBase(`/blog/${post.id}`)}>
                  {post.data.heroImage && (
                    <img
                      src={withBase(post.data.heroImage)}
                      alt={post.data.heroAlt ?? post.data.title}
                      loading="lazy"
                    />
                  )}
                  <h3>{post.data.title}</h3>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}
  </article>
</Layout>

<style>
  /* Paper, not white. Every bio on the live site sits on the off-white
     ground and it's what stops the page reading as a bare document. */
  .bio {
    background: var(--color-surface-muted);
    padding-top: var(--space-6);
    padding-bottom: var(--space-9);
  }

  .back a {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-label);
  }

  .back a:hover {
    color: var(--color-accent);
  }

  /* One grid for the whole bio: portrait left, everything else (name, role,
     location and the copy itself) stacked in the right column. Splitting it
     into a header row plus a full-width body pushed the copy underneath the
     portrait, which left a tall empty gap beside it. */
  .bio-layout {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    gap: var(--space-8);
    align-items: start;
    margin: var(--space-6) 0 var(--space-8);
  }

  /* The portrait is much shorter than the copy, so pin it while the text
     scrolls past rather than leaving it stranded at the top. */
  .portrait {
    position: sticky;
    top: var(--space-8);
  }

  .bio-main {
    min-width: 0;
  }

  /* Portrait dimensions, not a square crop: these are shot as portraits and
     squaring them cuts the top of people's heads off. */
  .portrait {
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-border);
  }

  .portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portrait-hover {
    opacity: 0;
    transition: opacity var(--transition);
  }

  .portrait:hover .portrait-hover {
    opacity: 1;
  }

  .bio-main h1 {
    font-size: var(--text-display-lg);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-4);
  }

  .role {
    color: var(--color-accent);
    font-size: var(--text-label);
    margin: 0 0 var(--space-4);
  }

  .caret {
    margin-right: var(--space-2);
  }

  .linkedin {
    display: inline-grid;
    place-items: center;
    width: var(--space-6);
    height: var(--space-6);
    border-radius: var(--radius-circle);
    background: var(--color-surface-inverted);
    color: var(--color-surface-muted);
    transition: background var(--transition);
  }

  .linkedin svg {
    width: 60%;
    height: 60%;
    fill: currentColor;
  }

  .linkedin:hover {
    background: var(--color-accent);
  }

  /* The coral rule the live bios carry under the name block. */
  .meta-rule {
    border: 0;
    border-top: var(--border-width) solid var(--color-accent);
    margin: var(--space-5) 0;
  }

  .location {
    font-weight: var(--weight-bold);
    margin: 0 0 var(--space-6);
  }

  /* --- Questions ---------------------------------------------------------- */
  /* The coral rule above this block is how the live site marks it out, and
     it's the one moment of brand colour on an otherwise plain page. */
  .questions {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: var(--border-width-button) solid var(--color-accent);
  }

  .questions h2 {
    font-size: var(--text-h2);
    margin: 0 0 var(--space-5);
    max-width: var(--measure-narrow);
  }

  .questions ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .questions li {
    padding: var(--space-4) 0;
    border-bottom: var(--border-width) solid var(--color-border);
    font-size: var(--text-body);
  }

  .questions li:first-child {
    padding-top: 0;
  }

  /* --- Authored posts ----------------------------------------------------- */
  /* The bio itself is paper, so the writing block goes white to keep the
     two apart (see the panel-rhythm rule in CLAUDE.md). */
  .authored {
    margin-top: var(--space-9);
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
    background: var(--color-surface);
  }

  .authored h2 {
    font-size: var(--text-display);
    margin: 0 0 var(--space-6);
  }

  .post-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .post-card {
    display: block;
    text-decoration: none;
    color: var(--color-text);
  }

  .post-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: var(--space-3);
  }

  .post-card h3 {
    font-size: var(--text-h3);
    margin: 0;
  }

  .post-card:hover h3 {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .bio-layout {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    /* Sticky is meaningless in a single column. */
    .portrait {
      position: static;
    }
  }
</style>
