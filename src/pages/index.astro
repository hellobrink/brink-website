---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../lib/base';

import { getCollection } from 'astro:content';

// Front page, styled after fundinnovation.dev's structure but kept in
// Brink's skin (Signifier / coral / square). Sections: photographic hero,
// three full-width image panels (work / methods / foundation), the
// since-2018 key-figures band that counts up on scroll, a latest-news grid
// pulled live from the blog collection, and "Who we are".

// The three latest posts, newest first. Real content, no carousel — FID's
// news carousel is hard to scroll, so we take the idea and drop the mechanism.
const posts = await getCollection('blog');
const latestPosts = posts
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

// Full-width image panels replacing the old three-up "Explore Brink" cards.
// `align` alternates the text side for rhythm and drives the scrim
// direction so the copy always sits over the darkened edge.
const panels = [
  {
    kicker: 'Our work',
    title: 'Addressing the world&rsquo;s most pressing issues',
    text: 'Health, education and climate — programmes designed with the people closest to the challenge.',
    href: withBase('/our-work'),
    image: '/images/panel-work.jpg',
    alt: 'Two people examining field data together on a Brink programme',
    align: 'left',
  },
  {
    kicker: 'Our methods',
    title: 'Obvious solutions to non-trivial problems',
    text: 'How we work with our partners — behavioural science and innovation methods, together.',
    href: withBase('/offers'),
    image: '/images/panel-methods.jpg',
    alt: 'A Brink workshop in progress, ideas mapped across a table',
    align: 'right',
  },
  {
    kicker: 'Our foundation',
    title: 'Imagining a better future, and making it happen',
    text: 'Bringing people together to grow the ideas that change how the world works.',
    href: withBase('/foundation'),
    image: '/images/panel-foundation.jpg',
    alt: 'Two women tending seedlings in a plant nursery',
    align: 'left',
  },
];
---

<Layout title="Home" overlayHeader>
  <section class="hero">
    <picture>
      <source
        media="(max-width: 900px)"
        srcset={withBase('/images/hero-sowing-field-1400.jpg')}
      />
      <img
        class="hero-image"
        src={withBase('/images/hero-sowing-field.jpg')}
        alt="A farmer sowing by hand across a freshly ploughed field, with green hills behind"
        fetchpriority="high"
      />
    </picture>
    <div class="hero-text">
      <h1>Innovation as if people matter</h1>
      <p>
        At Brink we create bold, innovative strategies to tackle urgent and
        preventable issues and drive impact in education, health, climate
        and more.
      </p>
      <a class="button inverted" href={withBase('/about')}>About Brink</a>
    </div>
  </section>

  {panels.map((panel) => (
    <a class:list={['panel', panel.align]} href={panel.href}>
      <img class="panel-image" src={withBase(panel.image)} alt={panel.alt} loading="lazy" />
      <div class="panel-inner">
        <div class="panel-text">
          <p class="mono kicker">{panel.kicker}</p>
          <h2 class="display" set:html={panel.title} />
          <p class="panel-lead">{panel.text}</p>
          <span class="mono read-more">Explore &rarr;</span>
        </div>
      </div>
    </a>
  ))}

  <section class="section stats">
    <div class="container">
      <h2 class="mono">Since 2018 Brink has</h2>
      <div class="stats-row">
        {/* The number carries the heading (matching the live site's markup),
            but a heading reading just "340" is meaningless in a screen
            reader's heading list — aria-label gives it the whole stat. */}
        <div class="stat">
          <span class="stat-lead">Supported over</span>
          <h3 class="stat-value display" data-count-to="340" aria-label="Supported over 340 innovation teams">340</h3>
          <span class="stat-label">innovation teams</span>
        </div>
        <div class="stat">
          <span class="stat-lead">across</span>
          <h3 class="stat-value display" data-count-to="53" aria-label="Across 53 countries">53</h3>
          <span class="stat-label">countries</span>
        </div>
        <div class="stat">
          <span class="stat-lead">to access more than</span>
          <h3 class="stat-value display" data-count-to="60" data-prefix="£" data-suffix="m" aria-label="To access more than £60m in funding">£60m</h3>
          <span class="stat-label">in funding</span>
        </div>
      </div>
    </div>
  </section>

  {latestPosts.length > 0 && (
    <section class="section news">
      <div class="container">
        <div class="news-head">
          <h2 class="display">Latest news</h2>
          <a class="mono read-more" href={withBase('/blog')}>All posts &rarr;</a>
        </div>
        <ul class="news-grid">
          {latestPosts.map((post) => (
            <li>
              <a class="news-card" href={withBase(`/blog/${post.id}`)}>
                {post.data.heroImage && (
                  <img src={withBase(post.data.heroImage)} alt={post.data.heroAlt ?? post.data.title} loading="lazy" />
                )}
                <div class="news-body">
                  {post.data.authorName && <p class="mono meta">{post.data.authorName}</p>}
                  <h3>{post.data.title}</h3>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="section who">
    <div class="container who-inner">
      <img
        class="who-photo"
        src={withBase('/images/6821fa6c49603a0725e6fee9_brink-retreat-25-team.jpeg')}
        alt="The Brink team together at their 2025 retreat"
      />
      <div class="who-body">
        <h2 class="display who-heading">Who we are</h2>
        <p class="who-statement">
          We're a global team of technologists, designers, strategists, and
          behavioural scientists, united by a commitment to harnessing
          technology for transformative impact
        </p>
        <p>
          Working alongside our partners we create ideas that put human
          behaviour at their core.
        </p>
        <p>
          By integrating insights from psychology, anthropology, sociology,
          and economics, we create the mindsets and mechanisms that deliver
          real change.
        </p>
        <a class="button" href={withBase('/team')}>Read more</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Count the key figures up as they scroll into view. The final value is
  // already in the HTML, so this degrades to a plain number if JS fails —
  // and it's skipped entirely for anyone who prefers reduced motion.
  const stats = document.querySelectorAll<HTMLElement>('[data-count-to]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (stats.length && !reduced) {
    const run = (el: HTMLElement) => {
      const target = Number(el.dataset.countTo);
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';
      const finalText = `${prefix}${target}${suffix}`;
      const duration = 1100;
      const start = performance.now();
      let done = false;
      const settle = () => {
        if (done) return;
        done = true;
        el.textContent = finalText;
      };
      const tick = (now: number) => {
        if (done) return;
        const p = Math.min((now - start) / duration, 1);
        // easeOutCubic — fast then settling, rather than a linear crawl
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = `${prefix}${Math.round(target * eased)}${suffix}`;
        if (p < 1) requestAnimationFrame(tick);
        else settle();
      };
      // requestAnimationFrame pauses when the tab isn't painting, which can
      // strand the counter part-way. A timeout backstop and a
      // visibility-change handler both guarantee it lands on the real value.
      setTimeout(settle, duration + 300);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) settle();
      });
      requestAnimationFrame(tick);
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          run(entry.target as HTMLElement);
          io.unobserve(entry.target); // count once, not on every scroll past
        });
      },
      { threshold: 0.6 }
    );
    stats.forEach((s) => io.observe(s));
  }
</script>

<style>
  /* Full-bleed photographic hero. The subject sits centre-right (sowing
     into the open field on her right), so a teal scrim fading from the left
     carries the copy over the empty green hillside without covering her. A
     flat overlay across the whole frame would just mute the photo. */
  .hero {
    position: relative;
    min-height: min(88vh, 760px);
    display: flex;
    align-items: center;
    padding: var(--space-9) 0;
    background: var(--color-surface-inverted);
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Bias toward the top so the transparent nav can't clip her head when a
       wide, short viewport crops the frame vertically. */
    object-position: 62% 32%;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(6, 51, 61, 0.92) 0%,
      rgba(6, 51, 61, 0.75) 32%,
      rgba(6, 51, 61, 0.15) 62%,
      rgba(6, 51, 61, 0) 78%
    );
  }

  .hero-text {
    position: relative;
    z-index: 1;
    color: var(--color-surface);
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--space-gutter);
  }

  /* The container is centred on the page, but the copy should sit in the
     scrim on the left rather than the middle of the photo. */
  @media (min-width: 901px) {
    .hero-text {
      margin: 0;
      padding-left: max(var(--space-gutter), calc((100vw - var(--max-width)) / 2 + var(--space-gutter)));
      max-width: calc(640px + (100vw - var(--max-width)) / 2);
    }
  }

  .hero-text h1 {
    font-size: var(--text-hero);
    color: var(--color-surface);
    margin-bottom: var(--space-4);
  }

  .hero-text p {
    font-size: var(--text-lead);
    margin-bottom: var(--space-6);
    max-width: 46ch;
  }

  /* Photo credit. Real people in real programmes deserve a name, and it
     doubles as proof the work is real. */
  .hero-credit {
    position: absolute;
    right: var(--space-gutter);
    bottom: var(--space-4);
    z-index: 1;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    text-align: right;
    max-width: 40ch;
  }

  @media (max-width: 900px) {
    .hero-credit {
      position: static;
      text-align: left;
      padding: var(--space-3) var(--space-gutter) 0;
      color: var(--color-text-muted);
    }
  }

  .section {
    padding: var(--space-8) 0;
    border-bottom: var(--border-width) solid var(--color-rule);
  }

  .section:last-of-type {
    border-bottom: none;
  }

  .kicker {
    color: var(--color-accent);
    font-weight: var(--weight-body);
    margin: 0 0 var(--space-3);
  }

  .read-more {
    color: var(--color-accent);
    font-size: var(--text-tag);
  }

  /* --- Full-width image panels (work / methods / foundation) --------------
     Each is a full-bleed link: photo, directional teal scrim, and copy that
     sits over the darkened edge. `align` flips the copy side and the scrim
     direction so the two always agree. */
  .panel {
    position: relative;
    display: block;
    min-height: min(70vh, 620px);
    color: var(--color-surface);
    text-decoration: none;
    overflow: hidden;
  }

  .panel-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .panel:hover .panel-image {
    transform: scale(1.03);
  }

  .panel::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .panel.left::after {
    background: linear-gradient(
      100deg,
      rgba(6, 51, 61, 0.88) 0%,
      rgba(6, 51, 61, 0.6) 34%,
      rgba(6, 51, 61, 0.1) 62%,
      rgba(6, 51, 61, 0) 80%
    );
  }

  .panel.right::after {
    background: linear-gradient(
      260deg,
      rgba(6, 51, 61, 0.88) 0%,
      rgba(6, 51, 61, 0.6) 34%,
      rgba(6, 51, 61, 0.1) 62%,
      rgba(6, 51, 61, 0) 80%
    );
  }

  .panel-inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-gutter);
    min-height: min(70vh, 620px);
    display: flex;
    align-items: center;
  }

  .panel.right .panel-inner {
    justify-content: flex-end;
  }

  .panel-text {
    max-width: 30rem;
  }

  .panel .kicker {
    color: var(--color-surface);
    opacity: 0.85;
  }

  .panel h2.display {
    font-size: var(--text-display);
    color: var(--color-surface);
    margin-bottom: var(--space-4);
  }

  .panel-lead {
    font-size: var(--text-lead);
    margin-bottom: var(--space-5);
  }

  .panel .read-more {
    color: var(--color-surface);
  }

  .panel:hover .read-more {
    text-decoration: underline;
  }

  @media (max-width: 700px) {
    /* On a phone the scrim can't clear enough of a busy photo, so drop a
       flat wash and left-align every panel. */
    .panel.right .panel-inner {
      justify-content: flex-start;
    }
    .panel.left::after,
    .panel.right::after {
      background: rgba(6, 51, 61, 0.72);
    }
  }

  /* --- Latest news -------------------------------------------------------- */
  .news-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .news-head h2.display {
    font-size: var(--text-display);
    margin: 0;
  }

  .news-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-grid-gap);
  }

  .news-card {
    display: block;
    height: 100%;
    color: var(--color-text);
    text-decoration: none;
  }

  .news-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    margin-bottom: var(--space-3);
  }

  .news-card .meta {
    color: var(--color-accent);
    margin: 0 0 var(--space-2);
  }

  .news-card h3 {
    font-size: var(--text-h3);
    margin: 0;
  }

  .news-card:hover h3 {
    text-decoration: underline;
  }

  .stats h2.mono {
    color: var(--color-text-muted);
    font-weight: var(--weight-body);
    margin: 0 0 var(--space-6);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-grid-gap);
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-lead {
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
  }

  .stat-value {
    font-size: var(--text-stat);
    font-weight: var(--weight-display);
    color: var(--color-accent);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .stat-label {
    font-size: var(--text-body);
  }

  .who-inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-8);
    align-items: center;
  }

  .who-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  .who-heading {
    font-size: var(--text-display);
    margin-bottom: var(--space-4);
  }

  .who-statement {
    font-weight: var(--weight-bold);
  }

  @media (max-width: 768px) {
    .who-photo {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-8) var(--space-gutter);
    }

    .who-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
