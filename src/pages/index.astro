---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../lib/base';

import { getCollection } from 'astro:content';

// Front page, styled after fundinnovation.dev's structure but kept in
// Brink's skin (Signifier / coral / square).
//
// Section order alternates photography with white space rather than running
// the image blocks together: photographic hero -> "Who we are" on white ->
// the work/methods/foundation carousel -> since-2018 key figures (counts up
// on scroll) -> latest news from the blog collection.

// The three latest posts, newest first. Real content, no carousel — FID's
// news carousel is hard to scroll, so we take the idea and drop the mechanism.
const posts = await getCollection('blog');
const latestPosts = posts
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

// Full-width image panels replacing the old three-up "Explore Brink" cards,
// shown as a horizontal carousel rather than stacked. Copy sits left on
// every slide: slides replace each other in the same spot, so alternating
// the side would make the text jump as it rotates.
const panels = [
  {
    kicker: 'Our work',
    title: 'Addressing the world&rsquo;s most pressing issues',
    text: 'Health, education and climate: programmes designed with the people closest to the challenge.',
    href: withBase('/our-work'),
    image: '/images/panel-work.jpg',
    alt: 'Two people examining field data together on a Brink programme',
  },
  {
    kicker: 'Our methods',
    title: 'Non-obvious solutions to non-trivial problems',
    text: 'How we work with our partners: behavioural science and innovation methods, together.',
    href: withBase('/offers'),
    image: '/images/panel-methods.jpg',
    alt: 'A Brink workshop in progress, ideas mapped across a table',
  },
  {
    kicker: 'Our foundation',
    title: 'Imagining a better future, and making it happen',
    text: 'Bringing people together to grow the ideas that change how the world works.',
    href: 'https://www.brink-foundation.org/',
    external: true,
    image: '/images/panel-foundation.jpg',
    alt: 'Two women tending seedlings in a plant nursery',
  },
];
---

<Layout title="Home" overlayHeader>
  <section class="hero">
    <picture>
      <source
        media="(max-width: 900px)"
        srcset={withBase('/images/hero-sowing-field-1400.jpg')}
      />
      <img
        class="hero-image"
        src={withBase('/images/hero-sowing-field.jpg')}
        alt="A farmer sowing by hand across a freshly ploughed field, with green hills behind"
        fetchpriority="high"
      />
    </picture>
    <div class="hero-text">
      <h1>Innovation as if people matter</h1>
      <p>
        At Brink we create bold, innovative strategies to tackle urgent and
        preventable issues and drive impact in education, health, climate
        and more.
      </p>
      <a class="button inverted" href={withBase('/about')}>About Brink</a>
    </div>
  </section>

  <section class="section who">
    <div class="container who-inner">
      <img
        class="who-photo"
        src={withBase('/images/6821fa6c49603a0725e6fee9_brink-retreat-25-team.jpeg')}
        alt="The Brink team together at their 2025 retreat"
      />
      <div class="who-body">
        <h2 class="display who-heading">Who we are</h2>
        <p class="who-statement">
          We're a global team of technologists, designers, strategists, and
          behavioural scientists, united by a commitment to harnessing
          technology for transformative impact
        </p>
        <p>
          Working alongside our partners we create ideas that put human
          behaviour at their core.
        </p>
        <p>
          By integrating insights from psychology, anthropology, sociology,
          and economics, we create the mindsets and mechanisms that deliver
          real change.
        </p>
        <a class="button" href={withBase('/team')}>Meet the team</a>
      </div>
    </div>
  </section>

  {/* Horizontal carousel, not a stack. Three full-bleed photo panels sat
      directly on top of each other read as one undifferentiated wall of
      imagery — and directly under the photographic hero, worse. Native
      scroll-snap does the work: it drags, swipes, and keyboard-scrolls for
      free, and still shows all three slides if JS never runs. */}
  <section class="panel-carousel" aria-roledescription="carousel" aria-label="What Brink does">
    <div class="panel-track" tabindex="0">
      {panels.map((panel, i) => (
        <a
          class="panel"
          href={panel.href}
          {...(panel.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} of ${panels.length}: ${panel.kicker}`}
        >
          <img class="panel-image" src={withBase(panel.image)} alt={panel.alt} loading="lazy" />
          <div class="panel-inner">
            <div class="panel-text">
              <p class="mono kicker">{panel.kicker}</p>
              <h2 class="display" set:html={panel.title} />
              <p class="panel-lead">{panel.text}</p>
              <span class="mono read-more">Explore {panel.kicker.toLowerCase()} &rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="carousel-controls">
      <button class="carousel-arrow" data-carousel-prev aria-label="Previous slide">&larr;</button>
      <div class="carousel-dots" role="tablist" aria-label="Choose slide">
        {panels.map((panel, i) => (
          <button
            class="carousel-dot"
            role="tab"
            data-carousel-dot={i}
            aria-label={panel.kicker}
            aria-selected={i === 0 ? 'true' : 'false'}
          ></button>
        ))}
      </div>
      <button class="carousel-arrow" data-carousel-next aria-label="Next slide">&rarr;</button>
    </div>
  </section>

  <section class="section stats">
    <div class="container">
      <h2 class="display stats-heading">Since 2018 Brink has</h2>
      <div class="stats-row">
        {/* The number carries the heading (matching the live site's markup),
            but a heading reading just "340" is meaningless in a screen
            reader's heading list — aria-label gives it the whole stat. */}
        <div class="stat">
          <span class="stat-caption">Supported over</span>
          <h3 class="stat-value display" data-count-to="340" aria-label="Supported over 340 innovation teams">340</h3>
          <span class="stat-caption">innovation teams</span>
        </div>
        <div class="stat">
          <span class="stat-caption">across</span>
          <h3 class="stat-value display" data-count-to="53" aria-label="Across 53 countries">53</h3>
          <span class="stat-caption">countries</span>
        </div>
        <div class="stat">
          <span class="stat-caption">to access more than</span>
          <h3 class="stat-value display" data-count-to="60" data-prefix="£" data-suffix="m" aria-label="To access more than £60m in funding">£60m</h3>
          <span class="stat-caption">in funding</span>
        </div>
      </div>
    </div>
  </section>

  {latestPosts.length > 0 && (
    <section class="section news">
      <div class="container">
        <div class="news-head">
          <h2 class="display">Latest thinking</h2>
          <a class="mono read-more" href={withBase('/blog')}>All posts &rarr;</a>
        </div>
        <ul class="news-grid">
          {latestPosts.map((post) => (
            <li>
              <a class="news-card" href={withBase(`/blog/${post.id}`)}>
                {/* Square card + square thumbnail, so the images aren't cropped. */}
                {post.data.heroImage && (
                  <img src={withBase(post.data.heroImage)} alt={post.data.heroAlt ?? post.data.title} loading="lazy" />
                )}
                <div class="news-body">
                  {(() => {
                    const authors = [post.data.authorName, post.data.authorName2].filter(Boolean).join(' & ');
                    return authors && <p class="mono meta">{authors}</p>;
                  })()}
                  <h3>{post.data.title}</h3>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}
</Layout>

<script>
  // --- Panel carousel -------------------------------------------------------
  // The scrolling itself is native scroll-snap; this only adds the arrows,
  // dots, and auto-rotation on top. If it never runs, the track is still a
  // perfectly usable horizontal scroller.
  const track = document.querySelector<HTMLElement>('.panel-track');
  const carousel = document.querySelector<HTMLElement>('.panel-carousel');

  if (track && carousel) {
    const dots = [...carousel.querySelectorAll<HTMLElement>('[data-carousel-dot]')];
    const slides = track.children.length;
    const wantsReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const indexOfScroll = () => Math.round(track.scrollLeft / track.clientWidth);

    // The slide movement is animated by hand rather than with
    // `scrollTo({ behavior: 'smooth' })`. That looks like the obvious call,
    // but it is a silent no-op on a scroll-snap container in some engines
    // (and wherever the user has animations switched off at OS level) — the
    // arrows would simply do nothing, with no error to show for it. A manual
    // rAF tween always moves.
    const goTo = (i: number) => {
      const target = ((i + slides) % slides) * track.clientWidth;
      const from = track.scrollLeft;
      const distance = target - from;
      if (!distance) return;

      // Reduced motion: honour it properly by jumping, not sliding.
      if (wantsReducedMotion.matches) {
        track.scrollLeft = target;
        return;
      }

      const duration = 500;
      const start = performance.now();
      let settled = false;
      // Snap would fight a frame-by-frame scroll, so lift it for the tween
      // and restore it after — the restore lands us exactly on the slide.
      track.style.scrollSnapType = 'none';
      const settle = () => {
        if (settled) return;
        settled = true;
        track.scrollLeft = target;
        track.style.scrollSnapType = '';
        syncDots();
      };
      const step = (now: number) => {
        if (settled) return;
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
        track.scrollLeft = from + distance * eased;
        if (p < 1) requestAnimationFrame(step);
        else settle();
      };
      // rAF stalls in a background tab; without this the track could be left
      // mid-slide with snapping still disabled.
      setTimeout(settle, duration + 300);
      requestAnimationFrame(step);
    };

    const syncDots = () => {
      const current = indexOfScroll();
      dots.forEach((dot, i) => dot.setAttribute('aria-selected', String(i === current)));
    };
    track.addEventListener('scroll', syncDots, { passive: true });

    // Auto-rotate, but never fight the user: pause while they're hovering,
    // tabbing through, or touching, and stand down entirely for reduced
    // motion or a background tab.
    let timer: ReturnType<typeof setInterval> | null = null;
    const stop = () => {
      if (timer) clearInterval(timer);
      timer = null;
    };
    const play = () => {
      stop();
      if (wantsReducedMotion.matches || document.hidden) return;
      timer = setInterval(() => goTo(indexOfScroll() + 1), 7000);
    };

    carousel.querySelector('[data-carousel-prev]')?.addEventListener('click', () => {
      goTo(indexOfScroll() - 1);
      play(); // restart the clock so a manual jump gets a full interval
    });
    carousel.querySelector('[data-carousel-next]')?.addEventListener('click', () => {
      goTo(indexOfScroll() + 1);
      play();
    });
    dots.forEach((dot, i) =>
      dot.addEventListener('click', () => {
        goTo(i);
        play();
      })
    );

    ['pointerenter', 'focusin', 'touchstart'].forEach((e) =>
      carousel.addEventListener(e, stop, { passive: true })
    );
    ['pointerleave', 'focusout'].forEach((e) => carousel.addEventListener(e, play));
    document.addEventListener('visibilitychange', () => (document.hidden ? stop() : play()));
    wantsReducedMotion.addEventListener('change', play);

    // Only rotate while it's actually on screen — no point animating a
    // carousel the reader has already scrolled past.
    new IntersectionObserver(([entry]) => (entry.isIntersecting ? play() : stop()), {
      threshold: 0.4,
    }).observe(carousel);

    syncDots();
  }

  // Count the key figures up as they scroll into view. The final value is
  // already in the HTML, so this degrades to a plain number if JS fails —
  // and it's skipped entirely for anyone who prefers reduced motion.
  const stats = document.querySelectorAll<HTMLElement>('[data-count-to]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (stats.length && !reduced) {
    const run = (el: HTMLElement) => {
      const target = Number(el.dataset.countTo);
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';
      const finalText = `${prefix}${target}${suffix}`;
      const duration = 1100;
      const start = performance.now();
      let done = false;
      const settle = () => {
        if (done) return;
        done = true;
        el.textContent = finalText;
      };
      const tick = (now: number) => {
        if (done) return;
        const p = Math.min((now - start) / duration, 1);
        // easeOutCubic — fast then settling, rather than a linear crawl
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = `${prefix}${Math.round(target * eased)}${suffix}`;
        if (p < 1) requestAnimationFrame(tick);
        else settle();
      };
      // requestAnimationFrame pauses when the tab isn't painting, which can
      // strand the counter part-way. A timeout backstop and a
      // visibility-change handler both guarantee it lands on the real value.
      setTimeout(settle, duration + 300);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) settle();
      });
      requestAnimationFrame(tick);
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          run(entry.target as HTMLElement);
          io.unobserve(entry.target); // count once, not on every scroll past
        });
      },
      { threshold: 0.6 }
    );
    stats.forEach((s) => io.observe(s));
  }
</script>

<style>
  /* Full-bleed photographic hero. The subject sits centre-right (sowing
     into the open field on her right), so a teal scrim fading from the left
     carries the copy over the empty green hillside without covering her. A
     flat overlay across the whole frame would just mute the photo. */
  .hero {
    position: relative;
    min-height: min(88vh, 760px);
    display: flex;
    align-items: center;
    padding: var(--space-9) 0;
    background: var(--color-surface-inverted);
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Bias toward the top so the transparent nav can't clip her head when a
       wide, short viewport crops the frame vertically. */
    object-position: 62% 32%;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(6, 51, 61, 0.92) 0%,
      rgba(6, 51, 61, 0.75) 32%,
      rgba(6, 51, 61, 0.15) 62%,
      rgba(6, 51, 61, 0) 78%
    );
  }

  .hero-text {
    position: relative;
    z-index: 1;
    color: var(--color-surface);
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--space-gutter);
  }

  /* The container is centred on the page, but the copy should sit in the
     scrim on the left rather than the middle of the photo. */
  @media (min-width: 901px) {
    .hero-text {
      margin: 0;
      padding-left: max(var(--space-gutter), calc((100vw - var(--max-width)) / 2 + var(--space-gutter)));
      max-width: calc(640px + (100vw - var(--max-width)) / 2);
    }
  }

  .hero-text h1 {
    font-size: var(--text-hero);
    color: var(--color-surface);
    margin-bottom: var(--space-4);
  }

  .hero-text p {
    font-size: var(--text-lead);
    margin-bottom: var(--space-6);
    max-width: 46ch;
  }

  /* Photo credit. Real people in real programmes deserve a name, and it
     doubles as proof the work is real. */
  .hero-credit {
    position: absolute;
    right: var(--space-gutter);
    bottom: var(--space-4);
    z-index: 1;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    text-align: right;
    max-width: 40ch;
  }

  @media (max-width: 900px) {
    .hero-credit {
      position: static;
      text-align: left;
      padding: var(--space-3) var(--space-gutter) 0;
      color: var(--color-text-muted);
    }
  }

  .section {
    padding: var(--space-8) 0;
    border-bottom: var(--border-width) solid var(--color-rule);
  }

  .section:last-of-type {
    border-bottom: none;
  }

  .kicker {
    color: var(--color-accent);
    font-weight: var(--weight-body);
    margin: 0 0 var(--space-3);
  }

  /* Teal, not coral: 12.8px coral on a light ground is 3.01:1 and fails AA.
     Panels override this to white where it sits over a photo. */
  .read-more {
    color: var(--color-label);
    font-size: var(--text-tag);
  }

  /* --- Panel carousel (work / methods / foundation) ----------------------
     Horizontal scroll-snap track, not a vertical stack. Three full-bleed
     photo panels stacked on top of each other — and sat straight under a
     photographic hero — read as one undifferentiated wall of imagery.
     Native scroll-snap handles drag, swipe, trackpad and keyboard for free;
     the arrows and dots are additions, not the mechanism. */
  .panel-carousel {
    position: relative;
  }

  .panel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* the dots and arrows are the affordance */
  }

  .panel-track::-webkit-scrollbar {
    display: none;
  }

  .panel-track:focus-visible {
    outline: var(--border-width-button) solid var(--color-accent);
    outline-offset: calc(var(--space-1) * -1);
  }

  .panel {
    position: relative;
    flex: 0 0 100%;
    scroll-snap-align: start;
    min-height: min(70vh, 620px);
    color: var(--color-surface);
    text-decoration: none;
    overflow: hidden;
  }

  .panel-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .panel:hover .panel-image {
    transform: scale(1.03);
  }

  /* Copy sits left on every slide, so the scrim always darkens the left. */
  .panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(6, 51, 61, 0.88) 0%,
      rgba(6, 51, 61, 0.6) 34%,
      rgba(6, 51, 61, 0.1) 62%,
      rgba(6, 51, 61, 0) 80%
    );
  }

  .panel-inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-gutter);
    min-height: min(70vh, 620px);
    display: flex;
    align-items: center;
  }

  .panel-text {
    max-width: 30rem;
  }

  .panel .kicker {
    color: var(--color-surface);
    opacity: 0.85;
  }

  .panel h2.display {
    font-size: var(--text-display);
    color: var(--color-surface);
    margin-bottom: var(--space-4);
  }

  .panel-lead {
    font-size: var(--text-lead);
    margin-bottom: var(--space-5);
  }

  .panel .read-more {
    color: var(--color-surface);
  }

  .panel:hover .read-more {
    text-decoration: underline;
  }

  /* Controls sit over the photo's bottom-right — the quiet corner, opposite
     the copy, on all three images. */
  .carousel-controls {
    position: absolute;
    z-index: 2;
    right: max(var(--space-gutter), calc((100vw - var(--max-width)) / 2 + var(--space-gutter)));
    bottom: var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .carousel-arrow {
    width: var(--space-7);
    height: var(--space-7);
    display: grid;
    place-items: center;
    background: transparent;
    border: var(--border-width-button) solid var(--color-surface);
    border-radius: var(--radius);
    color: var(--color-surface);
    font-family: var(--font-mono);
    font-size: var(--text-body);
    line-height: 1;
    cursor: pointer;
    transition: background var(--transition), color var(--transition);
  }

  .carousel-arrow:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .carousel-dots {
    display: flex;
    gap: var(--space-2);
  }

  /* Square, like everything else in the brand — no pills. */
  .carousel-dot {
    width: var(--space-6);
    height: var(--space-1);
    padding: 0;
    border: none;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: background var(--transition);
  }

  .carousel-dot:hover {
    background: rgba(255, 255, 255, 0.8);
  }

  .carousel-dot[aria-selected='true'] {
    background: var(--color-accent);
  }

  @media (max-width: 700px) {
    /* On a phone the directional scrim can't clear enough of a busy photo,
       so drop a flat wash instead. */
    .panel::after {
      background: rgba(6, 51, 61, 0.72);
    }

    /* Centred under the copy, clear of the thumb-reach edges. */
    .carousel-controls {
      right: auto;
      left: 0;
      width: 100%;
      justify-content: center;
    }
  }

  /* --- Latest thinking -------------------------------------------------------- */
  .news-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .news-head h2.display {
    font-size: var(--text-display);
    margin: 0;
  }

  .news-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-grid-gap);
  }

  .news-card {
    display: block;
    height: 100%;
    color: var(--color-text);
    text-decoration: none;
  }

  .news-card img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    margin-bottom: var(--space-3);
  }

  .news-card .meta {
    color: var(--color-label);
    margin: 0 0 var(--space-2);
  }

  .news-card h3 {
    font-size: var(--text-h3);
    margin: 0;
  }

  .news-card:hover h3 {
    text-decoration: underline;
  }

  /* Two type treatments in this band, not four: the Signifier section
     heading (identical to "Who we are" and "Latest thinking", so all three
     read as peers) and the big Signifier numeral. The words above and below
     each number share one caption style, so the numeral is the only change
     of register. */
  .stats-heading {
    font-size: var(--text-display);
    margin: 0 0 var(--space-7);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-grid-gap);
  }

  /* The caption words are centred on the numeral rather than left-aligned
     under it, so "Supported over / 340 / innovation teams" reads as one
     centred stack. */
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .stat-caption {
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .stat-value {
    font-size: var(--text-stat);
    font-weight: var(--weight-display);
    color: var(--color-accent);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .who-inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-8);
    align-items: center;
  }

  .who-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
