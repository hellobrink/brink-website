---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../lib/base';

import { getCollection } from 'astro:content';

// Hand-built to mirror the live hellobrink.co homepage: full-height coral
// hero (cranes_on_red, the same asset the live site uses), "What Brink is
// doing" cards, the three-column "Innovation as if people matter" section,
// the since-2018 stats band, and "Who we are". Verified against the live
// page: it renders exactly three content images, all on the pillar cards.
// Don't add sections that aren't there.

// The blog card pulls the newest post from the collection rather than
// hardcoding it, so it can't go stale.
const posts = await getCollection('blog');
const latestPost = posts.sort((a, b) => a.data.sortOrder - b.data.sortOrder)[0];

const doingCards = [
  {
    image: '/images/69398d70a7c114cc4eff4490_collage-trees-texture.png',
    kicker: 'What Brink is doing',
    title: 'We are now part of Africa Practice',
    text: "A message from Brink's founders on what this means.",
    href: withBase('/about'),
    external: false,
  },
  latestPost && {
    image: latestPost.data.heroImage ?? '/images/6a4f6c5d35f990c9cf987053_climate_funds.png',
    kicker: 'From the blog',
    title: latestPost.data.title,
    text: '',
    href: withBase(`/blog/${latestPost.id}`),
    external: false,
  },
  {
    image: '/images/6a4e0c6303419236b24b3df8_dont-believe-the-hype-83.png',
    kicker: 'Our latest newsletter',
    title: "Don't believe the hype! How not to get swept away on a BS wave.",
    text: '',
    // The newsletter lives on Mailchimp, not in the CMS.
    href: 'https://www.hellobrink.co/blog',
    external: true,
  },
].filter(Boolean);

// Each pillar carries a photo on the live homepage — these are the three
// images issue #2 reported missing. They belong here, on the cards; they
// are not a separate section.
const pillars = [
  {
    title: 'Our work',
    text: "Addressing some of the world's most pressing issues across health, education and climate.",
    href: withBase('/our-work'),
    image: '/images/67a4b5647b7d815f752aec59_01-violet-ochieng.jpg',
    alt: 'Violet Ochieng at work',
  },
  {
    title: 'Our methods',
    text: 'How we work with our partners to find obvious solutions to non-trivial problems.',
    href: withBase('/offers'),
    image: '/images/67a497c61d1d0f21b88108df_brinkcandids-172.jpg',
    alt: 'A Brink workshop in progress',
  },
  {
    title: 'Our foundation',
    text: 'Bringing people together to imagine a better future and make that future happen.',
    href: withBase('/foundation'),
    image: '/images/69f0866dc6488c88aef482d8_girl_in_green_top_in_african_class_looks_at_camera_-_ca.png',
    alt: 'A pupil looking up from her work in class',
  },
];
---

<Layout title="Home" overlayHeader>
  <section class="hero">
    <picture>
      <source
        media="(max-width: 900px)"
        srcset={withBase('/images/hero-sowing-field-1400.jpg')}
      />
      <img
        class="hero-image"
        src={withBase('/images/hero-sowing-field.jpg')}
        alt="A farmer sowing by hand across a freshly ploughed field, with green hills behind"
        fetchpriority="high"
      />
    </picture>
    <div class="hero-text">
      <h1>Innovation as if people matter</h1>
      <p>
        At Brink we create bold, innovative strategies to tackle urgent and
        preventable issues and drive impact in education, health, climate
        and more.
      </p>
      <a class="button inverted" href={withBase('/about')}>About Brink</a>
    </div>
  </section>

  <section class="section doing">
    <div class="container">
      <div class="card-row">
        {doingCards.map((card) => (
          <a
            class="card"
            href={card.href}
            target={card.external ? '_blank' : undefined}
            rel={card.external ? 'noopener' : undefined}
          >
            <img src={card.image.startsWith('http') ? card.image : withBase(card.image)} alt="" />
            <h2 class="mono kicker">{card.kicker}</h2>
            <h3>{card.title}</h3>
            {card.text && <p>{card.text}</p>}
            <span class="mono read-more">Read more &gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section pillars">
    <div class="container">
      <h2 class="display">Explore Brink</h2>
      <div class="card-row">
        {pillars.map((pillar) => (
          <a class="card" href={pillar.href}>
            <img src={withBase(pillar.image)} alt={pillar.alt} />
            <h3>{pillar.title}</h3>
            <p>{pillar.text}</p>
            <span class="mono read-more">Read more &gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section stats">
    <div class="container">
      <h2 class="mono">Since 2018 Brink has</h2>
      <div class="stats-row">
        {/* The number carries the heading (matching the live site's markup),
            but a heading reading just "340" is meaningless in a screen
            reader's heading list — aria-label gives it the whole stat. */}
        <div class="stat">
          <span class="stat-lead">Supported over</span>
          <h3 class="stat-value display" data-count-to="340" aria-label="Supported over 340 innovation teams">340</h3>
          <span class="stat-label">innovation teams</span>
        </div>
        <div class="stat">
          <span class="stat-lead">across</span>
          <h3 class="stat-value display" data-count-to="53" aria-label="Across 53 countries">53</h3>
          <span class="stat-label">countries</span>
        </div>
        <div class="stat">
          <span class="stat-lead">to access more than</span>
          <h3 class="stat-value display" data-count-to="60" data-prefix="£" data-suffix="m" aria-label="To access more than £60m in funding">£60m</h3>
          <span class="stat-label">in funding</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section who">
    <div class="container who-inner">
      <img
        class="who-photo"
        src={withBase('/images/6821fa6c49603a0725e6fee9_brink-retreat-25-team.jpeg')}
        alt="The Brink team together at their 2025 retreat"
      />
      <div class="who-body">
        <h2 class="display who-heading">Who we are</h2>
        <p class="who-statement">
          We're a global team of technologists, designers, strategists, and
          behavioural scientists, united by a commitment to harnessing
          technology for transformative impact
        </p>
        <p>
          Working alongside our partners we create ideas that put human
          behaviour at their core.
        </p>
        <p>
          By integrating insights from psychology, anthropology, sociology,
          and economics, we create the mindsets and mechanisms that deliver
          real change.
        </p>
        <a class="button" href={withBase('/team')}>Read more</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Count the key figures up as they scroll into view. The final value is
  // already in the HTML, so this degrades to a plain number if JS fails —
  // and it's skipped entirely for anyone who prefers reduced motion.
  const stats = document.querySelectorAll<HTMLElement>('[data-count-to]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (stats.length && !reduced) {
    const run = (el: HTMLElement) => {
      const target = Number(el.dataset.countTo);
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';
      const duration = 1100;
      const start = performance.now();
      const tick = (now: number) => {
        const p = Math.min((now - start) / duration, 1);
        // easeOutCubic — fast then settling, rather than a linear crawl
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = `${prefix}${Math.round(target * eased)}${suffix}`;
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          run(entry.target as HTMLElement);
          io.unobserve(entry.target); // count once, not on every scroll past
        });
      },
      { threshold: 0.6 }
    );
    stats.forEach((s) => io.observe(s));
  }
</script>

<style>
  /* Full-bleed photographic hero. The subject sits centre-right (sowing
     into the open field on her right), so a teal scrim fading from the left
     carries the copy over the empty green hillside without covering her. A
     flat overlay across the whole frame would just mute the photo. */
  .hero {
    position: relative;
    min-height: min(88vh, 760px);
    display: flex;
    align-items: center;
    padding: var(--space-9) 0;
    background: var(--color-surface-inverted);
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Bias toward the subject as the viewport narrows and crops the sides. */
    object-position: 60% center;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(6, 51, 61, 0.92) 0%,
      rgba(6, 51, 61, 0.75) 32%,
      rgba(6, 51, 61, 0.15) 62%,
      rgba(6, 51, 61, 0) 78%
    );
  }

  .hero-text {
    position: relative;
    z-index: 1;
    color: var(--color-surface);
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--space-gutter);
  }

  /* The container is centred on the page, but the copy should sit in the
     scrim on the left rather than the middle of the photo. */
  @media (min-width: 901px) {
    .hero-text {
      margin: 0;
      padding-left: max(var(--space-gutter), calc((100vw - var(--max-width)) / 2 + var(--space-gutter)));
      max-width: calc(640px + (100vw - var(--max-width)) / 2);
    }
  }

  .hero-text h1 {
    font-size: var(--text-hero);
    color: var(--color-surface);
    margin-bottom: var(--space-4);
  }

  .hero-text p {
    font-size: var(--text-lead);
    margin-bottom: var(--space-6);
    max-width: 46ch;
  }

  /* Photo credit. Real people in real programmes deserve a name, and it
     doubles as proof the work is real. */
  .hero-credit {
    position: absolute;
    right: var(--space-gutter);
    bottom: var(--space-4);
    z-index: 1;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    text-align: right;
    max-width: 40ch;
  }

  @media (max-width: 900px) {
    .hero-credit {
      position: static;
      text-align: left;
      padding: var(--space-3) var(--space-gutter) 0;
      color: var(--color-text-muted);
    }
  }

  .section {
    padding: var(--space-8) 0;
    border-bottom: var(--border-width) solid var(--color-rule);
  }

  .section:last-of-type {
    border-bottom: none;
  }

  .card-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-grid-gap);
  }

  .card {
    display: block;
    color: var(--color-text);
    text-decoration: none;
  }

  .card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    margin-bottom: var(--space-4);
  }

  /* These are semantic headings (matching the live site's markup) but must
     not inherit heading sizing — the kicker stays a small mono label and
     the card title stays body-weight. */
  .card h3 {
    font-size: var(--text-h2);
    margin-bottom: var(--space-2);
  }

  .card:hover h3 {
    text-decoration: underline;
  }

  .kicker {
    color: var(--color-text-muted);
    font-weight: var(--weight-body);
    margin: 0 0 var(--space-3);
  }

  .read-more {
    color: var(--color-accent);
  }

  .pillars h2.display {
    font-size: var(--text-display);
    margin-bottom: var(--space-6);
  }

  .pillars h3 {
    font-size: var(--text-h2);
  }

  .stats h2.mono {
    color: var(--color-text-muted);
    font-weight: var(--weight-body);
    margin: 0 0 var(--space-6);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-grid-gap);
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-lead {
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
  }

  .stat-value {
    font-size: var(--text-stat);
    font-weight: var(--weight-display);
    color: var(--color-accent);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .stat-label {
    font-size: var(--text-body);
  }

  .who-inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-8);
    align-items: center;
  }

  .who-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  .who-heading {
    font-size: var(--text-display);
    margin-bottom: var(--space-4);
  }

  .who-statement {
    font-weight: var(--weight-bold);
  }

  @media (max-width: 768px) {
    .who-photo {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-8) var(--space-gutter);
    }

    .who-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
