---
import Layout from '../../layouts/Layout.astro';
import LogoStrip from '../../components/LogoStrip.astro';
import { withBase } from '../../lib/base';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allWork = await getCollection('work');
  return allWork.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const { data } = item;
const tags = [...data.sector, ...data.offer];
---

<Layout title={data.title} description={data.summary}>
  <article class="container work-detail">
    <p class="back"><a href={withBase('/our-work')}>&larr; All work</a></p>

    {tags.length > 0 && (
      <div class="tags">
        {tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}

    {data.programmeName && <p class="kicker">{data.programmeName}</p>}
    <h1>{data.title}</h1>
    <p class="summary">{data.summary}</p>

    <LogoStrip names={[...data.funders, ...data.partners]} />

    {data.heroImage && <img class="hero" src={withBase(data.heroImage)} alt={data.heroAlt ?? data.title} />}

    {data.hasCaseStudy ? (
      <>
        {/* A label introducing the narrative. On the live site this is an
            optional CMS field, so it appears on some case studies and not
            others — we render it consistently instead. */}
        <h2 class="story-heading mono">The story in more detail</h2>
        <div class="prose">
          <Content />
        </div>
      </>
    ) : (
      <p class="light-entry-note">
        This is a summary entry — it doesn't have a full written case study yet.
        {data.externalLink && (
          <>
            {' '}Read more at <a href={data.externalLink} target="_blank" rel="noopener">{data.externalLink}</a>.
          </>
        )}
      </p>
    )}
  </article>
</Layout>

<style>
  .work-detail {
    padding: var(--space-6) 0 var(--space-9);
    max-width: var(--measure);
  }

  .work-detail h1 {
    font-size: var(--text-display-lg);
    line-height: var(--leading-tight);
  }

  .story-heading {
    color: var(--color-text-muted);
    font-weight: var(--weight-body);
    margin: var(--space-8) 0 var(--space-4);
    padding-top: var(--space-5);
    border-top: var(--border-width) solid var(--color-border);
  }

  .back a {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .tags {
    margin: var(--space-2) 0 var(--space-4);
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-muted);
    margin: var(--space-2) 0 0;
  }

  .summary {
    font-size: var(--text-body);
    color: var(--color-text-muted);
  }

  .hero {
    margin: var(--space-5) 0;
  }

  .prose :global(img) {
    width: auto;
    max-width: 100%;
    max-height: 520px;
    margin: var(--space-5) 0;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--text-display);
    line-height: 1.3;
    margin-top: var(--space-7);
  }

  .light-entry-note {
    background: var(--color-surface-muted);
    padding: var(--space-4);
    color: var(--color-text-muted);
  }
</style>
