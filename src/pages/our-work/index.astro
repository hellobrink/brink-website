---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
allWork.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

// Current work gets full-width hero bands, past work a compact grid. That
// split is exactly what `status` is for, so promoting a project to the top
// of this page is a one-word edit in its Markdown file:
//   status: current   ->  full-width band
//   status: past      ->  grid card
const current = allWork.filter((item) => item.data.status === 'current');

// Case studies that a current programme already links to via caseStudyRef are
// surfaced through that band, so keep them out of the past grid to avoid the
// same work appearing twice (EdTech Hub did).
const referenced = new Set(current.map((i) => i.data.caseStudyRef).filter(Boolean));
const past = allWork.filter((item) => item.data.status === 'past' && !referenced.has(item.id));

// Where "Read more" goes, in priority order. Most of this collection has no
// case study of its own: those entries belong to programmes that live on
// their own sites, and sending them to a thin internal summary page instead
// of the real thing was the wrong default.
//   1. its own case study, if it has one
//   2. a sibling entry's case study, if the write-up lives there
//   3. the programme's own site, opened in a new tab
function destination(item: (typeof allWork)[number]) {
  if (item.data.hasCaseStudy) {
    return { href: withBase(`/our-work/${item.id}`), external: false, label: 'Read the case study' };
  }
  if (item.data.caseStudyRef) {
    return { href: withBase(`/our-work/${item.data.caseStudyRef}`), external: false, label: 'Read the case study' };
  }
  if (item.data.externalLink) {
    return { href: item.data.externalLink, external: true, label: 'Visit the programme' };
  }
  return { href: withBase(`/our-work/${item.id}`), external: false, label: 'Read more' };
}

const sectors = ['climate', 'health', 'education'];
const offers = [
  { value: 'open-innovation', label: 'Open Innovation' },
  { value: 'carve-outs', label: 'Innovation Carve-Outs' },
  { value: 'missions', label: 'Innovation Missions' },
];
---

<Layout
  title="Our Work"
  description="Current and past programmes and projects, filterable by sector and offer."
>
  <div class="container">
    <header class="page-header">
      <h1>Our work</h1>
      <p>
        Every Brink engagement, current and past, in one place. Some open
        into a full write-up; others link out to the programme&rsquo;s own
        site. Filter by sector, offer or status below.
      </p>
    </header>

    <div class="filters" role="group" aria-label="Filter work">
      <div class="filter-group" data-filter-type="sector">
        <button type="button" class="filter-btn active" data-value="">All sectors</button>
        {sectors.map((s) => (
          <button type="button" class="filter-btn" data-value={s}>{s[0].toUpperCase() + s.slice(1)}</button>
        ))}
      </div>
      <div class="filter-group" data-filter-type="offer">
        <button type="button" class="filter-btn active" data-value="">All offers</button>
        {offers.map((o) => (
          <button type="button" class="filter-btn" data-value={o.value}>{o.label}</button>
        ))}
      </div>
      <div class="filter-group" data-filter-type="status">
        <button type="button" class="filter-btn active" data-value="">Current + past</button>
        <button type="button" class="filter-btn" data-value="current">Current</button>
        <button type="button" class="filter-btn" data-value="past">Past</button>
      </div>
    </div>

    <p class="empty-state" hidden>No work matches those filters.</p>

  </div>

  {/* Current work: full-width bands, alternating paper and teal so no two
      neighbours share a ground. Copy on the left with its credits beneath,
      photograph on the right stretched to match the copy's height. */}
  <section class="work-group" data-group="current">
    <div class="container">
      <h2 class="display group-heading">Current programmes and projects</h2>
    </div>

    {current.map((item, i) => (
      <div
        class:list={['work-item', 'work-band', i % 2 === 0 ? 'ground-paper' : 'ground-teal']}
        data-sector={item.data.sector.join(',')}
        data-offer={item.data.offer.join(',')}
        data-status={item.data.status}
      >
        <div class="container band-inner" data-dest={destination(item).href}>
          {/* The programme's name is the headline and its descriptive title
              becomes the standfirst beneath it. The other way round buried
              the name in a micro-kicker while a 90-character sentence did
              the shouting. */}
          <div class="band-copy">
            <h3 class="display band-name">
              <a
                href={destination(item).href}
                {...(destination(item).external
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                {item.data.programmeName ?? item.data.title}
              </a>
            </h3>
            {item.data.programmeName && <p class="band-tagline">{item.data.title}</p>}
            <p class="band-summary">{item.data.summary}</p>
            <span class="mono read-more">
              {destination(item).label}
              {destination(item).external ? ' \u2197' : ' \u2192'}
            </span>

            {/* Attribution, not calls to action: small, quiet, and under the
                link rather than competing with the photograph. */}
            {(item.data.funders.length > 0 || item.data.partners.length > 0) && (
              <div class="band-credits">
                {([['Funders', item.data.funders], ['Partners', item.data.partners]] as const).map(
                  ([label, list]) =>
                    list.length > 0 && (
                      <p class="credit">
                        <span class="mono credit-label">{label}</span>
                        {list.map((c, n) => (
                          <>
                            {n > 0 && <span class="sep" aria-hidden="true">·</span>}
                            {c.url ? (
                              <a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a>
                            ) : (
                              <span>{c.name}</span>
                            )}
                          </>
                        ))}
                      </p>
                    )
                )}
              </div>
            )}
          </div>

          {/* A photograph of the work, not the logomark. The logo is the
              brand; the photograph is the point. */}
          <div class="band-aside">
            {item.data.heroImage && (
              <img
                class="band-photo"
                src={withBase(item.data.heroImage)}
                alt={item.data.heroAlt ?? item.data.programmeName ?? item.data.title}
                loading="lazy"
              />
            )}
          </div>
        </div>
      </div>
    ))}
  </section>

  <div class="container">
    <section class="work-group past-group" data-group="past">
      <h2 class="display group-heading">Past programmes and projects</h2>
      <ul class="work-grid">
        {past.map((item) => (
          <li
            class="work-item"
            data-sector={item.data.sector.join(',')}
            data-offer={item.data.offer.join(',')}
            data-status={item.data.status}
          >
            <a
              href={destination(item).href}
              {...(destination(item).external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {item.data.heroImage && (
                <img src={withBase(item.data.heroImage)} alt={item.data.heroAlt ?? item.data.title} loading="lazy" />
              )}
              <div class="work-item-body">
                {item.data.hasCaseStudy && <span class="tag">Full case study</span>}
                {item.data.programmeName && <p class="mono kicker">{item.data.programmeName}</p>}
                <h3>{item.data.title}</h3>
                <p>{item.data.summary}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Layout>

<script>
  const state = { sector: '', offer: '', status: '' };
  const params = new URLSearchParams(location.search);
  for (const key of Object.keys(state)) {
    const value = params.get(key);
    if (value) state[key] = value;
  }

  const items = document.querySelectorAll('.work-item');
  const groupEls = document.querySelectorAll('.work-group');
  const emptyState = document.querySelector('.empty-state');

  function applyFilters() {
    let visibleCount = 0;
    items.forEach((el) => {
      const matches = Object.entries(state).every(([key, value]) => {
        if (!value) return true;
        const attr = el.getAttribute(`data-${key}`) || '';
        return attr.split(',').includes(value);
      });
      el.hidden = !matches;
      if (matches) visibleCount += 1;
    });
    groupEls.forEach((group) => {
      group.hidden = group.querySelectorAll('.work-item:not([hidden])').length === 0;
    });
    emptyState.hidden = visibleCount > 0;
  }

  document.querySelectorAll('.filter-group').forEach((group) => {
    const type = group.getAttribute('data-filter-type');
    group.querySelectorAll('.filter-btn').forEach((btn) => {
      if (btn.getAttribute('data-value') === state[type]) {
        group.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
      }
      btn.addEventListener('click', () => {
        state[type] = btn.getAttribute('data-value') || '';
        group.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const newParams = new URLSearchParams();
        for (const [key, value] of Object.entries(state)) {
          if (value) newParams.set(key, value);
        }
        history.replaceState(null, '', newParams.size ? `?${newParams}` : location.pathname);
        applyFilters();
      });
    });
  });

  applyFilters();
</script>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-5);
    max-width: var(--measure);
  }

  .group-heading {
    font-size: var(--text-display);
    margin: 0 0 var(--space-6);
  }

  /* --- Current work: full-width bands -------------------------------------- */
  .work-group[data-group='current'] {
    padding: var(--space-8) 0 var(--space-9);
  }

  .work-band {
    padding: var(--space-9) 0;
  }

  .work-band[hidden] {
    display: none;
  }

  .ground-paper {
    background: var(--color-surface-muted);
  }

  .ground-teal {
    background: var(--color-surface-inverted);
    color: var(--color-text-inverted);
  }

  /* `stretch`, so the row's height is set by the copy and the photograph
     matches it instead of floating centred against a taller column. */
  .band-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: stretch;
  }

  /* The photo is absolutely positioned inside this stretched cell rather
     than sized with a percentage height. A percentage would have to resolve
     against the grid area while the item is also being stretched by it,
     which browsers treat as cyclic and quietly drop: the same trap
     documented in LogoGrid.astro. inset:0 has no such problem. */
  .band-aside {
    position: relative;
    min-height: 18rem;
  }

  .band-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius);
    display: block;
  }

  .band-copy .kicker {
    color: var(--color-accent);
    margin: 0 0 var(--space-3);
  }

  .band-name {
    font-size: var(--text-display);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-3);
  }

  .band-tagline {
    font-size: var(--text-lead);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-4);
  }

  .ground-paper .band-tagline {
    color: var(--color-text);
  }

  .ground-teal .band-tagline {
    color: var(--color-surface);
  }

  .band-name a {
    color: inherit;
    text-decoration: none;
  }

  /* The whole band is the target, so the link stretches to cover it. */
  .band-name a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .work-band {
    position: relative;
  }

  .band-name a:hover {
    color: var(--color-accent);
  }

  .band-summary {
    font-size: var(--text-body-sm);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-5);
  }

  .ground-paper .read-more {
    color: var(--color-label);
  }

  .ground-teal .read-more {
    color: var(--color-surface);
  }

  .read-more {
    font-size: var(--text-tag);
  }

  .work-band:hover .read-more {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Above the band's stretched headline link, or the credits aren't
     clickable. Plain block flow: an earlier `display: grid` with a 24px gap
     survived a rewrite here and stacked on top of the paragraph margin,
     making a 32px gap between two lines that belong together. */
  .band-credits {
    position: relative;
    z-index: 1;
    margin-top: var(--space-5);
  }

  .credit {
    font-size: var(--text-tag);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-1);
  }

  .credit-label {
    font-size: var(--text-2xs);
    color: var(--color-accent);
    margin-right: var(--space-3);
  }

  .sep {
    margin: 0 var(--space-2);
    opacity: 0.5;
  }

  .ground-paper .credit {
    color: var(--color-text-muted);
  }

  .ground-teal .credit {
    color: var(--color-text-inverted);
    opacity: 0.75;
  }

  .credit a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .credit a:hover {
    color: var(--color-accent);
  }

  /* --- Past work: compact grid --------------------------------------------- */
  .past-group {
    padding: var(--space-9) 0;
  }

  .work-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-7) var(--space-6);
  }

  .work-item[hidden] {
    display: none;
  }

  .work-grid a {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    height: 100%;
  }

  .work-grid img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: var(--space-3);
  }

  .work-grid .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-label);
    border: var(--border-width) solid var(--color-border);
    padding: var(--space-1) var(--space-2);
    margin-bottom: var(--space-2);
  }

  .work-grid .kicker {
    color: var(--color-label);
    font-size: var(--text-tag);
    margin: 0 0 var(--space-1);
  }

  .work-grid h3 {
    font-size: var(--text-h3);
    margin: 0 0 var(--space-2);
  }

  .work-grid a:hover h3 {
    color: var(--color-accent);
  }

  .work-grid p {
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 800px) {
    .band-inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }

  .filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.4em 0.9em;
    border-radius: var(--radius);
    border: var(--border-width) solid var(--color-text-muted);
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
  }

  .filter-btn.active {
    background: var(--color-text);
    color: var(--color-surface-muted);
    border-color: var(--color-text);
  }

  .empty-state {
    color: var(--color-text-muted);
  }
</style>
