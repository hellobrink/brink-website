---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../lib/base';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Let the header sit transparent over a full-bleed hero image. */
  overlayHeader?: boolean;
}

const {
  title,
  description = 'Brink is a global team of technologists, designers, strategists, and behavioural scientists working on open innovation.',
  overlayHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={withBase('/images/brink-logotype-coral.png')} />
    <meta name="description" content={description} />
    <title>{title} · Brink</title>
  </head>
  <body>
    <Header overlay={overlayHeader} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
